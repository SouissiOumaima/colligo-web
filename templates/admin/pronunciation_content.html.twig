{% extends 'base.html.twig' %}

{% block title %}Admin - Gestion des Contenus{% endblock %}

{% block stylesheets %}
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
    <style>
        body {
            background: linear-gradient(to bottom right, #2c3e50, #3498db);
            font-family: 'Segoe UI', Helvetica, Arial, sans-serif;
            color: #fff;
            min-height: 100vh;
            display: flex;
            justify-content: center;
            align-items: center;
        }
        .container {
            max-width: 1100px;
            padding: 20px;
        }
        h1 {
            font-size: 40px;
            font-weight: bold;
            text-shadow: 0 4px 8px rgba(0, 0, 0, 0.5);
            text-align: center;
            margin-bottom: 20px;
        }
        .form-select, .form-control {
            background-color: #fff;
            border-radius: 8px;
            border: 1px solid #bdc3c7;
            box-shadow: 0 3px 6px rgba(0, 0, 0, 0.1);
            font-size: 14px;
            padding: 10px;
        }
        .btn {
            font-size: 16px;
            padding: 14px 40px;
            border-radius: 30px;
            box-shadow: 0 2px 6px rgba(0, 0, 0, 0.3);
            transition: transform 0.2s;
        }
        .btn:hover {
            transform: translateY(-2px);
        }
        .btn-primary {
            background: linear-gradient(to right, #1abc9c, #16a085);
            border: none;
        }
        .btn-success {
            background: linear-gradient(to right, #2ecc71, #27ae60);
            border: none;
        }
        .btn-danger {
            background: linear-gradient(to right, #e74c3c, #c0392b);
            border: none;
        }
        .table {
            background-color: #fff;
            border-radius: 8px;
            border: 1px solid #bdc3c7;
            box-shadow: 0 3px 6px rgba(0, 0, 0, 0.1);
        }
        .table th {
            background-color: #f8f9fa;
            font-weight: bold;
        }
        .table td {
            vertical-align: middle;
        }
        .alert {
            border-radius: 8px;
        }
        .form-group {
            margin-bottom: 15px;
        }
        .input-group {
            display: flex;
            gap: 10px;
        }
        .dual-language {
            display: flex;
            gap: 10px;
        }
        .dual-language label {
            margin: 0;
        }
    </style>
{% endblock %}

{% block body %}
    <div class="container">
        <h1>Gestion des Contenus - Admin</h1>

        {% for message in app.flashes('success') %}
            <div class="alert alert-success">{{ message }}</div>
        {% endfor %}
        {% for message in app.flashes('error') %}
            <div class="alert alert-danger">{{ message }}</div>
        {% endfor %}

        <!-- Manual Creation Form -->
       

        <!-- AI Generation Form -->
        <form method="post" class="mb-4">
            <h2 class="text-2xl font-bold text-gray-800 mb-4">Générer des contenus par IA</h2>
            <div class="input-group">
                <div class="form-group w-100">
                    <label for="langue" class="block text-lg font-semibold text-gray-700 mb-2">Langue</label>
                    <select name="langue" id="langue" class="form-select">
                        <option value="Français" {{ langue|lower == 'français' ? 'selected' : '' }}>Français</option>
                        <option value="Anglais" {{ langue|lower == 'anglais' ? 'selected' : '' }}>Anglais</option>
                        <option value="Espagnol" {{ langue|lower == 'espagnol' ? 'selected' : '' }}>Espagnol</option>
                        <option value="Allemand" {{ langue|lower == 'allemand' ? 'selected' : '' }}>Allemand</option>
                    </select>
                </div>
                <div class="form-group w-100">
                    <label for="niveau" class="block text-lg font-semibold text-gray-700 mb-2">Niveau</label>
                    <select name="niveau" id="niveau" class="form-select">
                        <option value="1" {{ niveau == 1 ? 'selected' : '' }}>Alphabet</option>
                        <option value="2" {{ niveau == 2 ? 'selected' : '' }}>Mots</option>
                        <option value="3" {{ niveau == 3 ? 'selected' : '' }}>Phrases</option>
                    </select>
                </div>
                <button type="submit" name="generate" value="1" class="btn btn-success">Générer</button>
                <a href="{{ path('admin_add_content') }}" class="btn btn-primary">Ajouter le contenu</a>
            </div>
        </form>

        <!-- Generated Contents Form -->
        {% if generatedContents is not empty %}
            <form method="post" class="mb-4">
                <h2 class="text-2xl font-bold text-gray-800 mb-4">Contenus générés</h2>
                <div class="input-group">
                    <input type="hidden" name="save_langue" value="{{ langue ?? 'Français' }}">
                    <input type="hidden" name="niveau" value="{{ niveau }}">
                    {% for content in generatedContents %}
                        <div class="form-check dual-language">
                            {% set parts = content|split(' | ', 2) %}
                            <input type="checkbox" name="contents[]" value="{{ content }}" id="content_{{ loop.index }}" class="form-check-input">
                            <label for="content_{{ loop.index }}" class="form-check-label text-gray-800">
                                {{ parts[0] }} <span style="color: #ff4500;">| {{ parts[1] ?? '' }}</span>
                            </label>
                        </div>
                    {% endfor %}
                    <button type="submit" name="save_generated" value="1" class="btn btn-primary">Enregistrer les contenus sélectionnés</button>
                </div>
            </form>
        {% endif %}

        <!-- Existing Contents Table -->
        <h2 class="text-2xl font-bold text-gray-800 mb-4">Contenus existants</h2>
        {% if contents is not empty %}
            <table class="table table-bordered">
                <thead>
                    <tr>
                        <th style="width: 35%;">Contenu</th>
                        <th style="width: 35%;">Traduction Arabe</th>
                        <th style="width: 10%;">Niveau</th>
                        <th style="width: 10%;">Langue</th>
                        <th style="width: 10%;">Action</th>
                    </tr>
                </thead>
                <tbody>
                    {% for content in contents %}
                        <tr>
                            <td>
                                {% set parts = content.content|split(' | ', 2) %}
                                {{ parts[0] }}
                            </td>
                            <td>
                                {{ parts[1] ?? '-' }}
                            </td>
                            <td>
                                {% if content.level == 1 %}Alphabet
                                {% elseif content.level == 2 %}Mots
                                {% elseif content.level == 3 %}Phrases
                                {% else %}Inconnu{% endif %}
                            </td>
                            <td>{{ content.langue }}</td>
                            <td>
                                <form method="post" action="{{ path('admin_pronunciation_content_delete', {'id': content.id}) }}" onsubmit="return confirm('Êtes-vous sûr de vouloir supprimer ce contenu ?');">
                                    <button type="submit" class="btn btn-danger btn-sm">Supprimer</button>
                                </form>
                            </td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        {% else %}
            <p class="text-gray-600 text-center">Aucun contenu trouvé.</p>
        {% endif %}
    </div>
{% endblock %}

{% block javascripts %}
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        document.addEventListener('DOMContentLoaded', () => {
            const forms = document.querySelectorAll('form');
            const clickSound = new Audio('/sons/click.mp3');

            forms.forEach(form => {
                form.addEventListener('submit', (e) => {
                    clickSound.play();
                });
            });
        });
    </script>
{% endblock %}