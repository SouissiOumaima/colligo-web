<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <title>Administration des thèmes</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        /* Custom styles for subtle enhancements */
        .table-hover tr:hover {
            background-color: #f9fafb;
            transition: background-color 0.2s;
        }
        .modal {
            display: none;
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background-color: rgba(0, 0, 0, 0.5);
            z-index: 50;
        }
        .modal-content {
            background-color: white;
            margin: 15% auto;
            padding: 20px;
            border-radius: 8px;
            width: 90%;
            max-width: 500px;
            box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);
        }
        .modal-close {
            cursor: pointer;
            float: right;
            font-size: 1.5rem;
            color: #6b7280;
        }
        .modal-close:hover {
            color: #ef4444;
        }
    </style>
</head>
<body class="bg-gray-50 text-gray-800 font-sans">
    <div class="container mx-auto p-6 max-w-7xl">
        <h1 class="text-4xl font-bold text-gray-900 mb-6 text-center">Gestion des thèmes</h1>

        <!-- Modal for flash messages -->
        <div id="flashModal" class="modal">
            <div class="modal-content">
                <span id="closeModal" class="modal-close">×</span>
                <div id="modalMessage"></div>
            </div>
        </div>

        <div class="mb-8">
            <h2 class="text-2xl font-semibold text-gray-700 mb-4">Filtre appliqué</h2>
            {% if filter_language or filter_level %}
                <p class="text-gray-600 mb-2">
                    Langue : <span class="font-medium">{{ filter_language|default('Aucune') }}</span> | 
                    Niveau : <span class="font-medium">{{ filter_level|default('Aucun') }}</span>
                    <a href="{{ path('admin_clear_filter') }}" class="text-indigo-600 hover:text-indigo-800 ml-4 font-medium">Effacer le filtre</a>
                </p>
            {% else %}
                <p class="text-gray-500">Aucun filtre appliqué.</p>
            {% endif %}
        </div>

        <form action="{{ path('admin_generate_themes') }}" method="post" class="mb-8 bg-white p-6 rounded-lg shadow-md">
            <div class="flex space-x-6 items-center">
                <select name="language" class="border-gray-300 rounded-lg p-2 focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500">
                    <option value="fr">Français</option>
                    <option value="en">Anglais</option>
                    <option value="de">Allemand</option>
                    <option value="es">Espagnol</option>
                </select>
                <select name="level" class="border-gray-300 rounded-lg p-2 focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500">
                    <option value="Facile">Facile</option>
                    <option value="Moyen">Moyen</option>
                    <option value="Difficile">Difficile</option>
                </select>
                <button type="submit" class="bg-yellow-500 text-white px-6 py-2 rounded-lg hover:bg-yellow-600 transition duration-200">Générer thèmes</button>
                <a href="{{ path('admin_add_theme') }}" class="bg-blue-500 text-white px-6 py-2 rounded-lg hover:bg-blue-600 transition duration-200">Ajouter un thème</a>
            </div>
        </form>

        <div class="bg-white rounded-lg shadow-md overflow-hidden">
            <table class="w-full table-hover">
                <thead>
                    <tr class="bg-gray-100">
                        <th class="border-b border-gray-200 p-4 text-left text-gray-600 font-medium">Nom</th>
                        <th class="border-b border-gray-200 p-4 text-left text-gray-600 font-medium">Langue</th>
                        <th class="border-b border-gray-200 p-4 text-left text-gray-600 font-medium">Niveau</th>
                        <th class="border-b border-gray-200 p-4 text-left text-gray-600 font-medium">Stage</th>
                        <th class="border-b border-gray-200 p-4 text-left text-gray-600 font-medium">Mots</th>
                        <th class="border-b border-gray-200 p-4 text-left text-gray-600 font-medium">Validé</th>
                        <th class="border-b border-gray-200 p-4 text-left text-gray-600 font-medium">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    {% if themes|length == 0 %}
                        <tr>
                            <td colspan="7" class="border-b border-gray-200 p-4 text-center text-gray-500">Aucun thème disponible avec les filtres actuels.</td>
                        </tr>
                    {% else %}
                        {% for theme in themes %}
                            <tr>
                                <td class="border-b border-gray-200 p-4">{{ theme.name }}</td>
                                <td class="border-b border-gray-200 p-4">{{ theme.language }}</td>
                                <td class="border-b border-gray-200 p-4">{{ theme.level }}</td>
                                <td class="border-b border-gray-200 p-4">{{ theme.stage }}</td>
                                <td class="border-b border-gray-200 p-4">
                                    {% for word in theme.words %}
                                        {{ word.word }} ({{ word.synonym }})<br>
                                    {% endfor %}
                                </td>
                                <td class="border-b border-gray-200 p-4">{{ theme.isValidated ? 'Oui' : 'Non' }}</td>
                                <td class="border-b border-gray-200 p-4">
                                    {% if not theme.isValidated %}
                                        <form action="{{ path('admin_validate_theme', {'id': theme.id}) }}" method="post" class="inline-block mr-2">
                                            <input type="hidden" name="_csrf_token" value="{{ csrf_token('validate_theme') }}">
                                            <button type="submit" class="bg-blue-500 text-white px-3 py-1 rounded hover:bg-blue-600 transition duration-200">Valider</button>
                                        </form>
                                    {% endif %}
                                    <form action="{{ path('admin_delete_theme', {'id': theme.id}) }}" method="post" class="inline-block">
                                        <input type="hidden" name="_csrf_token" value="{{ csrf_token('delete_theme') }}">
                                        <button type="submit" class="bg-red-500 text-white px-3 py-1 rounded hover:bg-red-600 transition duration-200">Supprimer</button>
                                    </form>
                                </td>
                            </tr>
                        {% endfor %}
                    {% endif %}
                </tbody>
            </table>
        </div>
    </div>

    <script>
        document.addEventListener('DOMContentLoaded', function() {
            const flashMessages = {
                success: '{{ app.flashes("success")|join("|")|escape("js") }}',
                error: '{{ app.flashes("error")|join("|")|escape("js") }}'
            };

            const modal = document.getElementById('flashModal');
            const modalMessage = document.getElementById('modalMessage');
            const closeModal = document.getElementById('closeModal');

            function showModal(type, messages) {
                if (messages) {
                    modalMessage.innerHTML = messages.split('|').map(msg => `<p class="${type === 'success' ? 'text-green-700 bg-green-100' : 'text-red-700 bg-red-100'} p-3 rounded mb-2">${msg}</p>`).join('');
                    modal.style.display = 'block';
                }
            }

            if (flashMessages.success) showModal('success', flashMessages.success);
            else if (flashMessages.error) showModal('error', flashMessages.error);

            closeModal.onclick = function() {
                modal.style.display = 'none';
            };

            window.onclick = function(event) {
                if (event.target === modal) {
                    modal.style.display = 'none';
                }
            };
        });
    </script>
</body>
</html>