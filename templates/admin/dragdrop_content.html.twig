{% extends 'base.html.twig' %}

{% block title %}Gestion des Phrases - Admin{% endblock %}

{% block stylesheets %}
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
    <style>
        body {
            background: linear-gradient(to bottom right, #2c3e50, #3498db);
            font-family: 'Segoe UI', Helvetica, Arial, sans-serif;
            color: #fff;
            min-height: 100vh;
            display: flex;
            justify-content: center;
            align-items: center;
        }
        .container {
            max-width: 1100px;
            padding: 20px;
        }
        h1 {
            font-size: 40px;
            font-weight: bold;
            text-shadow: 0 4px 8px rgba(0, 0, 0, 0.5);
            text-align: center;
            margin-bottom: 20px;
        }
        h2 {
            font-size: 24px;
            font-weight: bold;
            color: #fff;
            margin-bottom: 20px;
        }
        .form-select, .form-control {
            background-color: #fff;
            border-radius: 8px;
            border: 1px solid #bdc3c7;
            box-shadow: 0 3px 6px rgba(0, 0, 0, 0.1);
            font-size: 14px;
            padding: 10px;
        }
        .btn {
            font-size: 16px;
            padding: 14px 40px;
            border-radius: 30px;
            box-shadow: 0 2px 6px rgba(0, 0, 0, 0.3);
            transition: transform 0.2s;
        }
        .btn:hover {
            transform: translateY(-2px);
        }
        .btn-success {
            background: linear-gradient(to right, #2ecc71, #27ae60);
            border: none;
        }
        .table {
            background-color: #fff;
            border-radius: 8px;
            border: 1px solid #bdc3c7;
            box-shadow: 0 3px 6px rgba(0, 0, 0, 0.1);
        }
        .table th {
            background-color: #f8f9fa;
            font-weight: bold;
        }
        .table td {
            vertical-align: middle;
        }
        .alert {
            border-radius: 8px;
        }
        .form-group {
            margin-bottom: 15px;
        }
        .input-group {
            display: flex;
            gap: 10px;
        }
        .dual-language {
            display: flex;
            gap: 10px;
        }
        .dual-language label {
            margin: 0;
        }
    </style>
{% endblock %}

{% block body %}
    <div class="container">
        <h1>Gestion des Phrases - Admin</h1>

        {% for message in app.flashes('success') %}
            <div class="alert alert-success">{{ message }}</div>
        {% endfor %}
        {% for message in app.flashes('error') %}
            <div class="alert alert-danger">{{ message }}</div>
        {% endfor %}

        <!-- Manual Creation Form -->
        <form method="post" class="mb-4">
            {{ form_start(form) }}
            <div class="input-group">
                <div class="form-group w-100">
                    {{ form_label(form.phrase, null, {'label_attr': {'class': 'block text-lg font-semibold text-gray-700 mb-2'}}) }}
                    {{ form_widget(form.phrase, {'attr': {'class': 'form-control'}}) }}
                    {{ form_errors(form.phrase) }}
                </div>
                <div class="form-group w-100">
                    {{ form_label(form.arabicTranslation, null, {'label_attr': {'class': 'block text-lg font-semibold text-gray-700 mb-2'}}) }}
                    {{ form_widget(form.arabicTranslation, {'attr': {'class': 'form-control'}}) }}
                    {{ form_errors(form.arabicTranslation) }}
                </div>
                <div class="form-group w-100">
                    {{ form_label(form.niveau, null, {'label_attr': {'class': 'block text-lg font-semibold text-gray-700 mb-2'}}) }}
                    {{ form_widget(form.niveau, {'attr': {'class': 'form-select'}}) }}
                    {{ form_errors(form.niveau) }}
                </div>
                <div class="form-group w-100">
                    {{ form_label(form.langue, null, {'label_attr': {'class': 'block text-lg font-semibold text-gray-700 mb-2'}}) }}
                    {{ form_widget(form.langue, {'attr': {'class': 'form-select'}}) }}
                    {{ form_errors(form.langue) }}
                </div>
                <button type="submit" class="btn btn-success">Ajouter la phrase</button>
            </div>
            {{ form_end(form) }}
        </form>

        <!-- AI Generation Form -->
        <form method="post" class="mb-4">
            <h2>Générer des phrases par IA</h2>
            <div class="input-group">
                <div class="form-group w-100">
                    <label for="language" class="block text-lg font-semibold text-gray-700 mb-2">Langue</label>
                    <select name="language" id="language" class="form-select">
                        <option value="Français" {{ language == 'Français' ? 'selected' : '' }}>Français</option>
                        <option value="English" {{ language == 'English' ? 'selected' : '' }}>English</option>
                        <option value="Espagnol" {{ language == 'Espagnol' ? 'selected' : '' }}>Espagnol</option>
                        <option value="Allemand" {{ language == 'Allemand' ? 'selected' : '' }}>Allemand</option>
                    </select>
                </div>
                <div class="form-group w-100">
                    <label for="level" class="block text-lg font-semibold text-gray-700 mb-2">Niveau</label>
                    <select name="level" id="level" class="form-select">
                        <option value="0" {{ level == 0 ? 'selected' : '' }}>Niveau 0</option>
                        <option value="1" {{ level == 1 ? 'selected' : '' }}>Niveau 1</option>
                        <option value="2" {{ level == 2 ? 'selected' : '' }}>Niveau 2</option>
                        <option value="3" {{ level == 3 ? 'selected' : '' }}>Niveau 3</option>
                    </select>
                </div>
                <button type="submit" name="generate" value="1" class="btn btn-success">Générer</button>
            </div>
        </form>

        <!-- Generated Sentences Form -->
        {% if generatedSentences|length > 0 %}
            <form method="post" class="mb-4">
                <h2>Phrases générées</h2>
                <div class="input-group">
                    <input type="hidden" name="save_language" value="{{ language }}">
                    {% for sentence in generatedSentences %}
                        <div class="form-check dual-language">
                            {% set parts = sentence|split(' | ', 2) %}
                            <input type="checkbox" name="sentences[]" value="{{ sentence }}" id="sentence_{{ loop.index }}" class="form-check-input">
                            <label for="sentence_{{ loop.index }}" class="form-check-label text-gray-800">
                                {{ parts[0] }} <span style="color: #ff4500;">| {{ parts[1] ?? '' }}</span>
                            </label>
                        </div>
                    {% endfor %}
                    <button type="submit" name="save_generated" value="1" class="btn btn-success">Enregistrer les sélections</button>
                </div>
            </form>
        {% endif %}

        <!-- Existing Sentences Table -->
        <h2>Phrases existantes</h2>
        <table class="table table-bordered">
            <thead>
                <tr>
                    <th style="width: 50%;">Phrase</th>
                    <th>Niveau</th>
                    <th>Langue</th>
                </tr>
            </thead>
            <tbody>
                {% for dragdrop in dragdrops %}
                    <tr>
                        <td>{{ dragdrop.phrase }}</td>
                        <td>{{ dragdrop.niveau }}</td>
                        <td>{{ dragdrop.langue }}</td>
                    </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
{% endblock %}

{% block javascripts %}
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        document.addEventListener('DOMContentLoaded', () => {
            const forms = document.querySelectorAll('form');
            const clickSound = new Audio('/sons/click.mp3');

            forms.forEach(form => {
                form.addEventListener('submit', (e) => {
                    clickSound.play();
                });
            });
        });
    </script>
{% endblock %}