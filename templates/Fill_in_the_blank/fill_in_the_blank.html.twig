{% extends 'base.html.twig' %}

{% block title %}لعبة املأ الفراغات {% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link href="{{ asset('css/fill_in_the_blank.css') }}" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Chewy&display=swap" rel="stylesheet">
{% endblock %}

{% block body %}
    <div class="container-fluid game-container d-flex flex-column align-items-center justify-content-center min-vh-100">
        {% if completed %}
            <!-- Completion Screen -->
            <div class="text-center completion-screen">
                <h1 class="title-label mb-4">🎉 برافو يا بطل!</h1>
                <p class="completion-text">!!يعطيك الصحة كملت اللعبة بنجاح</p>
                <p class="score-label">النقاط: {{ score }} (المستوى {{ level }})</p>
                <div class="completion-animation mb-4"></div>
                <div class="back-button-container">
                    <a href="{{ path('child_dashboard', {'parentId': parent_id, 'childId': child_id}) }}" class="back-button">Retour au Tableau</a>
                </div>
            </div>
        {% else %}
            <!-- Game Screen -->
            <!-- Header with Child Info, Score, and Progress -->
            <div class="header-container d-flex justify-content-between align-items-center w-100 p-3">
                <!-- Child Info (Avatar and Name) -->
                <div class="child-info d-flex align-items-center">
                    <img src="{{ asset('avatars/' ~ child_avatar ~ '.png') }}" alt="Child Avatar" class="child-avatar">
                    <span class="child-name">{{ child_name }}</span>
                </div>

                <!-- Score and Progress -->
                <div class="score-container d-flex align-items-center">
                    <span class="score-label">النقاط: {{ score }} (المستوى {{ level }})</span>
                    <div class="progress-stars ml-3">
                        {% for i in 1..3 %}
                            <span class="star {% if i <= level %}filled{% endif %}">★</span>
                        {% endfor %}
                    </div>
                </div>
            </div>

            <!-- Top Feedback Phrase -->
            {% if feedback %}
                <div class="top-feedback text-center">
                    {% if feedback.type == 'correct' %}
                        <h2 class="top-feedback-message">صحيت لقيت الاجابة الصحيحة!🌟🎉</h2>
                    {% else %}
                        <h2 class="top-feedback-message">ميسالش عاود مرة أخرى! 💪</h2>
                    {% endif %}
                </div>
            {% endif %}

            <!-- Frame (Cadre) for Title, Question, and Answers -->
            <div class="cadre-container">
                <!-- Title -->
                <div class="title-label mb-3">اختار الكلمة الصحيحة</div>

                <!-- Question -->
                <div class="question-container text-center mb-4">
                    <div class="question-label bounce">
                        {{ question.question_text }}
                    </div>
                </div>

                <!-- Answer Buttons -->
                <div class="answer-container d-flex justify-content-center flex-wrap gap-3 mb-4">
                    {% for answer in answers %}
                        {% if answer %}
                            <form method="post" class="answer-form">
                                <input type="hidden" name="answer" value="{{ answer }}">
                                <button type="submit" class="answer-button pop-up">{{ answer }}</button>
                            </form>
                        {% endif %}
                    {% endfor %}
                </div>
            </div>

            {% if feedback %}
                <div class="feedback-area text-center mb-4">
                    {% if feedback.type == 'correct' %}
                        <img src="{{ asset('Gifs/correctAnswer1.gif') }}" class="feedback-gif" id="feedback-gif" alt="Correct Answer">
                    {% else %}
                        <img src="{{ asset('Gifs/incorrectAnswer1.gif') }}" class="feedback-gif" id="feedback-gif" alt="Incorrect Answer">
                    {% endif %}
                </div>
            {% endif %}
        {% endif %}
    </div>

    {% block javascripts %}
        {{ parent() }}
        <script src="https://cdn.jsdelivr.net/npm/canvas-confetti@1.5.1/dist/confetti.browser.min.js"></script>
        <script>
            document.addEventListener('DOMContentLoaded', function () {
                // Apply pop-up animation to answer buttons
                document.querySelectorAll('.answer-button').forEach(button => {
                    button.classList.add('pop-up');
                    // Add sound effect on click
                    button.addEventListener('click', () => {
                        const audio = new Audio('{{ asset('sounds/click.mp3') }}');
                        audio.play();
                        // Note: To play correct.mp3 or incorrect.mp3 on click, we need to know if the answer is correct
                        // at the time of the click, which isn't available until after form submission.
                        // Currently, correct.mp3 and incorrect.mp3 are played after feedback is received below.
                    });
                });

                // Show SweetAlert for errors
                {% if not questions %}
                    Swal.fire({
                        icon: 'error',
                        title: 'Oups !',
                        text: 'Aucune question trouvée pour ce niveau.',
                    });
                {% endif %}

                // Handle feedback GIF display and redirect
                const feedbackGif = document.getElementById('feedback-gif');
                if (feedbackGif) {
                    feedbackGif.classList.add('visible');
                    // Play sound and confetti for correct answers
                    {% if feedback and feedback.type == 'correct' %}
                        const audio = new Audio('{{ asset('sounds/correct1.mp3') }}');
                        audio.play();
                        confetti({
                            particleCount: 100,
                            spread: 70,
                            origin: { y: 0.6 }
                        });
                    {% endif %}
                    {% if feedback and feedback.type != 'correct' %}
                        const audio = new Audio('{{ asset('sounds/incorrect1.mp3') }}');
                        audio.play();
                    {% endif %}
                    setTimeout(() => {
                        window.location.href = '{{ path('fill_in_the_blank_play', {'parentId': parent_id, 'childId': child_id}) }}';
                    }, 3000);
                }
            });
        </script>
    {% endblock %}
{% endblock %}