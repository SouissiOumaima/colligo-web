{% extends 'base.html.twig' %}

{% block title %}لعبة النطق السحرية{% endblock %}

{% block stylesheets %}
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/animate.css/4.1.1/animate.min.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;700&family=Comic+Neue:wght@700&display=swap" rel="stylesheet">
    <style>
        :root {
            --primary-color: #ff6f61;
            --gradient-start: #ffcc80;
            --gradient-end: #80d8ff;
            --background-light: #fff3e0;
            --text-dark: #333;
            --text-grey: #666;
        }

        body {
            background: linear-gradient(135deg, var(--gradient-start), var(--primary-color), var(--gradient-end));
            font-family: 'Poppins', sans-serif;
            color: var(--text-dark);
            min-height: 100vh;
            display: flex;
            justify-content: center;
            align-items: center;
            overflow-x: hidden;
            margin: 0;
            direction: rtl;
        }

        .container {
            max-width: 800px;
            padding: 30px;
            text-align: center;
            background: #ffffff;
            border-radius: 25px;
            box-shadow: 0 15px 40px rgba(0, 0, 0, 0.15);
            border: 4px solid var(--primary-color);
            position: relative;
            transition: transform 0.3s ease;
        }

        .container:hover {
            transform: scale(1.02);
        }

        h1 {
            font-family: 'Comic Neue', cursive;
            font-size: 60px;
            color: var(--primary-color);
            margin-bottom: 20px;
            text-shadow: 2px 2px 5px rgba(255, 111, 97, 0.3);
            animation: bounceTitle 2s infinite;
        }

        .progress-bar {
            height: 15px;
            background: #e0e0e0;
            border-radius: 10px;
            overflow: hidden;
            margin: 20px auto;
            max-width: 600px;
        }

        .progress-bar-fill {
            height: 100%;
            background: linear-gradient(90deg, var(--gradient-end), var(--gradient-start));
            transition: width 0.5s ease;
        }

        .content-card {
            background: var(--background-light);
            border-radius: 20px;
            border: 3px dashed var(--gradient-end);
            padding: 30px;
            margin: 20px auto;
            max-width: 600px;
            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.1);
            position: relative;
        }

        .content-card::before {
            content: '🌟';
            position: absolute;
            top: -15px;
            right: -15px;
            font-size: 30px;
            animation: sparkle 2s infinite;
        }

        .prononcer {
            font-family: 'Comic Neue', cursive;
            font-size: 100px;
            color: var(--primary-color);
            font-weight: 700;
            margin-bottom: 20px;
            text-transform: uppercase;
            animation: pulseText 2s infinite;
        }

        .btn {
            font-size: 24px;
            padding: 15px 40px;
            border-radius: 30px;
            box-shadow: 0 8px 20px rgba(0, 0, 0, 0.2);
            transition: transform 0.3s ease, box-shadow 0.3s ease;
            margin: 10px;
            font-weight: 600;
            text-transform: uppercase;
            display: inline-flex;
            align-items: center;
            gap: 10px;
            border: none;
        }

        .btn:hover {
            transform: translateY(-5px);
            box-shadow: 0 12px 30px rgba(0, 0, 0, 0.3);
        }

        .btn-primary {
            background: linear-gradient(45deg, var(--gradient-end), #40c4ff);
            color: #fff;
        }

        .btn-success {
            background: linear-gradient(45deg, var(--gradient-start), #ffab40);
            color: #fff;
        }

        .btn i {
            font-size: 28px;
        }

        .btn:disabled {
            background: #ccc;
            transform: none;
            box-shadow: none;
            cursor: not-allowed;
        }

        p {
            font-size: 28px;
            color: var(--text-grey);
            margin-bottom: 20px;
            animation: fadeInUp 1s;
        }

        .navigation {
            display: flex;
            justify-content: center;
            gap: 20px;
            margin-top: 30px;
        }

        .recording-indicator {
            color: var(--primary-color);
            font-weight: 700;
            margin-top: 20px;
            animation: blinkText 1s infinite;
            font-size: 26px;
        }

        .modal {
            display: none;
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background-color: rgba(0, 0, 0, 0.5);
            justify-content: center;
            align-items: center;
            z-index: 1000;
            direction: rtl;
        }

        .modal-content {
            background: var(--background-light);
            padding: 30px;
            border-radius: 20px;
            text-align: center;
            max-width: 500px;
            box-shadow: 0 15px 40px rgba(0, 0, 0, 0.3);
            border: 3px solid var(--gradient-start);
            animation: popIn 0.5s;
        }

        .modal-message {
            font-size: 30px;
            color: var(--primary-color);
            margin-bottom: 20px;
        }

        .gif {
            max-width: 400px;
            border-radius: 15px;
            margin: 20px 0;
            animation: bounceGif 2s infinite;
        }

        @media (max-width: 768px) {
            .container {
                padding: 20px;
                border-width: 3px;
            }
            h1 {
                font-size: 40px;
            }
            .prononcer {
                font-size: 70px;
            }
            .btn {
                font-size: 20px;
                padding: 10px 30px;
            }
            p {
                font-size: 22px;
            }
            .modal-content {
                max-width: 90%;
                padding: 20px;
            }
            .modal-message {
                font-size: 24px;
            }
            .gif {
                max-width: 300px;
            }
        }

        @keyframes bounceTitle {
            0%, 100% { transform: translateY(0); }
            50% { transform: translateY(-10px); }
        }

        @keyframes pulseText {
            0% { transform: scale(1); }
            50% { transform: scale(1.05); }
            100% { transform: scale(1); }
        }

        @keyframes sparkle {
            0% { opacity: 0.5; }
            50% { opacity: 1; }
            100% { opacity: 0.5; }
        }

        @keyframes fadeInUp {
            0% { opacity: 0; transform: translateY(20px); }
            100% { opacity: 1; transform: translateY(0); }
        }

        @keyframes blinkText {
            50% { opacity: 0.7; }
        }

        @keyframes popIn {
            0% { transform: scale(0.8); opacity: 0; }
            100% { transform: scale(1); opacity: 1; }
        }

        @keyframes bounceGif {
            0%, 100% { transform: translateY(0); }
            50% { transform: translateY(-10px); }
        }
    </style>
{% endblock %}

{% block body %}
    <main class="container">
        <h1>لعبة النطق السحرية لـ {{ child.name }}! 🪄</h1>

        <p>
            المستوى: {% if level_number == 0 %}1{% else %}المستوى {{ level_number + 1 }}{% endif %} | اللغة: {{ child.language }} 🌟
            <span style="color: var(--primary-color);">النتيجة: {{ average_score }} ⭐</span>
        </p>

        <div class="progress-bar">
            <div class="progress-bar-fill" style="width: {{ content_size > 0 ? ((content_index + 1) / content_size * 100) : 0 }}%;"></div>
        </div>

        <section id="game-area">
            {% if current_content %}
                <div class="content-card">
                    <h2 class="prononcer" id="content-to-pronounce">{{ current_content.content }}</h2>
                    <input type="hidden" id="expected-text" value="{{ current_content.content }}">
                    <input type="hidden" id="child-id" value="{{ child.childId }}">
                    <input type="hidden" id="content-id" value="{{ current_content.id }}">
                    <div class="btn-group" role="group">
                        <button id="pronounce-btn" class="btn btn-primary"><i class="fas fa-volume-up"></i> استمع</button>
                        <button id="record-btn" class="btn btn-success" disabled><i class="fas fa-microphone"></i> تكلم</button>
                    </div>
                    <div id="recording-indicator" class="recording-indicator" style="display: none;">جارٍ التسجيل... 🎤</div>
                </div>
                <nav class="navigation">
                    <a href="{{ path('child_dashboard', {'parentId': child.parentId.parentId, 'childId': child.childId}) }}" class="btn btn-primary"><i class="fas fa-home"></i> عودة</a>
                    {% if content_index > 0 %}
                        <a href="{{ path('jeu_accueil', {'childId': child.childId, 'contentIndex': content_index - 1}) }}" class="btn btn-primary"><i class="fas fa-arrow-right"></i> السابق</a>
                    {% endif %}
                    {% if content_index < content_size - 1 %}
                        <a href="{{ path('jeu_accueil', {'childId': child.childId, 'contentIndex': content_index + 1}) }}" class="btn btn-primary"><i class="fas fa-arrow-left"></i> التالي</a>
                    {% endif %}
                </nav>
            {% else %}
                <p>لا توجد حروف للتعلم الآن! عود قريبًا! 🕒</p>
                <nav class="navigation">
                    <a href="{{ path('jeu_accueil', {'childId': child.childId}) }}" class="btn btn-primary"><i class="fas fa-home"></i> عودة</a>
                </nav>
            {% endif %}
        </section>
        <div id="modal" class="modal">
            <div class="modal-content">
                <p id="modal-message" class="modal-message"></p>
                <img id="modal-gif" class="gif" src="" alt="النتيجة">
                <audio id="modal-sound" autoplay></audio>
            </div>
        </div>
    </main>
{% endblock %}

{% block javascripts %}
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/js/all.min.js"></script>
    <script>
        document.addEventListener('DOMContentLoaded', () => {
            const pronounceBtn = document.getElementById('pronounce-btn');
            const recordBtn = document.getElementById('record-btn');
            const recordingIndicator = document.getElementById('recording-indicator');
            const modal = document.getElementById('modal');
            const modalMessage = document.getElementById('modal-message');
            const modalGif = document.getElementById('modal-gif');
            const modalSound = document.getElementById('modal-sound');
            const expectedText = document.getElementById('expected-text')?.value || 'default';
            const childId = document.getElementById('child-id')?.value || '1';
            const contentId = document.getElementById('content-id')?.value || '1';
            const contentToPronounce = document.getElementById('content-to-pronounce');
            let isProcessing = false;

            const correctSound = new Audio('/sounds/correct1.mp3');
            const incorrectSound = new Audio('/sounds/incorrect1.mp3');
            correctSound.preload = 'auto';
            incorrectSound.preload = 'auto';

            if (pronounceBtn) {
                pronounceBtn.addEventListener('click', () => {
                    const utterance = new SpeechSynthesisUtterance(contentToPronounce.textContent);
                    utterance.lang = 'ar';
                    utterance.pitch = 1.3;
                    utterance.rate = 0.7;
                    window.speechSynthesis.speak(utterance);
                    recordBtn.disabled = false;
                });
            }

            let mediaRecorder;
            let audioChunks = [];

            if (recordBtn) {
                navigator.mediaDevices.getUserMedia({ audio: true })
                    .then(stream => {
                        mediaRecorder = new MediaRecorder(stream);
                        mediaRecorder.ondataavailable = event => {
                            audioChunks.push(event.data);
                            console.log('تم تسجيل مقطع صوتي:', event.data.size);
                        };
                        mediaRecorder.onstop = () => {
                            if (isProcessing) return;
                            isProcessing = true;
                            recordBtn.disabled = true;
                            const audioBlob = new Blob(audioChunks, { type: 'audio/webm' });
                            audioChunks = [];
                            console.log('حجم الملف الصوتي:', audioBlob.size);
                            const formData = new FormData();
                            formData.append('audio', audioBlob, 'recording.webm');
                            formData.append('expectedText', expectedText);
                            formData.append('childId', childId);
                            formData.append('contentId', contentId);

                            console.log('إرسال الطلب بـ:', {
                                expectedText: expectedText,
                                childId: childId,
                                contentId: contentId,
                                audioBlobSize: audioBlob.size,
                            });

                            fetch('{{ path('verifier_pronunciation') }}', {
                                method: 'POST',
                                body: formData,
                            })
                            .then(response => {
                                console.log('حالة الاستجابة:', response.status);
                                if (!response.ok) {
                                    throw new Error('الاستجابة غير صحيحة: ' + response.statusText);
                                }
                                return response.json();
                            })
                            .then(data => {
                                console.log('تم استقبال الاستجابة:', JSON.stringify(data));
                                recordingIndicator.style.display = 'none';
                                modalMessage.textContent = data.message;
                                modalGif.src = data.gif;
                                modalSound.src = data.son;
                                modalSound.play().catch(error => console.error('فشل تشغيل الصوت:', error));
                                modal.style.display = 'flex';
                                console.log('التصحيح:', data.debug);

                                setTimeout(() => {
                                    modal.style.display = 'none';
                                    if (data.next) {
                                        window.location.href = '{{ path('jeu_accueil', {childId: child.childId}) }}';
                                    } else {
                                        const nextIndex = {{ content_index }} + 1;
                                        if (nextIndex < {{ content_size }}) {
                                            window.location.href = '{{ path('jeu_accueil', {childId: child.childId}) }}?contentIndex=' + nextIndex;
                                        } else {
                                            alert('مبروك! أنت بطل سحري! 🎉🌟');
                                            window.location.reload();
                                        }
                                    }
                                }, 2500);
                            })
                            .catch(error => {
                                console.error('خطأ في الاستعلام:', error.message);
                                recordingIndicator.style.display = 'none';
                                modalMessage.textContent = 'جهد رائع! لقد حصلت على 3 نجوم! 🌟 (نقبل كل المحاولات للاستمتاع!)';
                                modalGif.src = '/images/gifs/sahyt.gif';
                                modalSound.src = '/sons/correct.mp3';
                                modalSound.play().catch(err => console.error('فشل تشغيل الصوت:', err));
                                modal.style.display = 'flex';

                                setTimeout(() => {
                                    modal.style.display = 'none';
                                    const nextIndex = {{ content_index }} + 1;
                                    if (nextIndex < {{ content_size }}) {
                                        window.location.href = '{{ path('jeu_accueil', {childId: child.childId}) }}?contentIndex=' + nextIndex;
                                    } else {
                                        alert('مبروك! أنت بطل سحري! 🎉🌟');
                                        window.location.reload();
                                    }
                                }, 2500);
                            })
                            .finally(() => {
                                isProcessing = false;
                                recordBtn.disabled = false;
                            });
                        };

                        recordBtn.addEventListener('click', () => {
                            if (isProcessing) return;
                            recordingIndicator.style.display = 'block';
                            mediaRecorder.start();
                            setTimeout(() => {
                                mediaRecorder.stop();
                            }, 3500);
                        });
                    })
                    .catch(error => {
                        console.error('خطأ في الوصول إلى الميكروفون:', error);
                        alert('فعّل ميكروفونك السحري للعب! 🎙️');
                    });
            }

            document.querySelectorAll('.navigation a').forEach(link => {
                link.addEventListener('click', (e) => {
                    console.log('تم النقر على التنقل:', link.href);
                });
            });
        });
    </script>
{% endblock %}