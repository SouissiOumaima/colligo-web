<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Sélection de la langue</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        body {
            background-color: #f0f0f0;
        }
        .language-button {
            background-color: #ADD8E6;
            min-width: 150px;
            min-height: 50px;
            font-size: 18px;
        }
        .alert {
            padding: 10px;
            margin-bottom: 10px;
            border-radius: 5px;
        }
        .alert-success {
            background-color: #d4edda;
            color: #155724;
        }
        .alert-danger {
            background-color: #f8d7da;
            color: #721c24;
        }
    </style>
</head>
<body class="flex items-center justify-center min-h-screen">
    <div class="bg-white bg-opacity-80 p-8 rounded-lg shadow-lg text-center space-y-6">
        <h1 class="text-2xl font-bold">Sélectionnez une langue</h1>
        {% for message in app.flashes('success') %}
            <div class="alert alert-success">
                {{ message }}
            </div>
        {% endfor %}
        {% for message in app.flashes('error') %}
            <div class="alert alert-danger">
                {{ message }}
            </div>
        {% endfor %}
        <form method="POST" action="{{ path('language_selection') }}">
            <div class="flex flex-col space-y-4">
                <button type="submit" name="language" value="fr" class="language-button">Français</button>
                <button type="submit" name="language" value="en" class="language-button">English</button>
                <button type="submit" name="language" value="de" class="language-button">Deutsch</button>
                <button type="submit" name="language" value="es" class="language-button">Español</button>
            </div>
        </form>
    </div>
</body>
</html>