<!DOCTYPE html>
<html lang="ar">
<head>
    <meta charset="UTF-8">
    <title>Jeu de correspondance magique</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Comic+Neue:wght@700&display=swap" rel="stylesheet">
    <style>
        body {
            background: linear-gradient(135deg, #f5efe6 0%, #D9CFC1 100%);
            font-family: 'Comic Neue', cursive;
            overflow-x: hidden;
        }
        .game-container {
            background: url('https://www.transparenttextures.com/patterns/rice-paper.png'), rgba(255, 255, 255, 0.95);
            border: 5px solid #E8E8F5;
            border-radius: 20px;
            padding: 20px;
            box-shadow: 0 10px 20px rgba(0, 0, 0, 0.1);
            animation: bounceIn 0.5s ease;
        }
        @keyframes bounceIn {
            0% { transform: scale(0.9); opacity: 0; }
            50% { transform: scale(1.05); }
            100% { transform: scale(1); opacity: 1; }
        }
        .word-button, .synonym-button {
            background-color: #FFFFFF;
            color: #5A4B6B;
            min-width: 120px;
            min-height: 60px;
            font-size: 20px;
            border-radius: 15px;
            border: 3px solid #D4E4D7;
            transition: transform 0.3s, background-color 0.3s;
            position: relative;
            overflow: hidden;
        }
        .word-button::before, .synonym-button::before {
            content: '🌟';
            position: absolute;
            top: -10px;
            left: -10px;
            font-size: 30px;
            opacity: 0;
            transition: opacity 0.3s;
        }
        .word-button:hover, .synonym-button:hover {
            transform: scale(1.1);
            background-color: #F5F5F5;
        }
        .word-button:hover::before, .synonym-button:hover::before {
            opacity: 0.5;
        }
        .selected {
            background-color: #C9E4F5 !important;
            transform: scale(1.05) !important;
        }
        .matched {
            background-color: #E8E8F5 !important;
            color: #5A4B6B;
            transform: scale(1.1) !important;
            animation: sparkle 1s infinite;
        }
        @keyframes sparkle {
            0% { box-shadow: 0 0 5px #D4E4D7; }
            50% { box-shadow: 0 0 15px #D4E4D7; }
            100% { box-shadow: 0 0 5px #D4E4D7; }
        }
        .button-container {
            display: flex;
            justify-content: center;
            gap: 30px;
            margin: 20px 0;
        }
        .word-column, .synonym-column {
            display: flex;
            flex-direction: column;
            gap: 15px;
            align-items: center;
        }
        #modal, #level-modal {
            display: none;
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(0, 0, 0, 0.5);
            justify-content: center;
            align-items: center;
            z-index: 1000;
            animation: fadeIn 0.3s ease;
        }
        @keyframes fadeIn {
            from { opacity: 0; }
            to { opacity: 1; }
        }
        .modal-content {
            background: #F5F5DC;
            padding: 25px;
            border-radius: 20px;
            border: 5px solid #D4E4D7;
            box-shadow: 0 10px 20px rgba(0, 0, 0, 0.2);
            width: 80%;
            max-width: 500px;
            text-align: center;
            animation: popIn 0.5s ease;
        }
        @keyframes popIn {
            0% { transform: scale(0.8); opacity: 0; }
            50% { transform: scale(1.1); }
            100% { transform: scale(1); opacity: 1; }
        }
        #modal-message, #level-modal-message {
            font-size: 24px;
            color: #A89EBF;
            margin-bottom: 15px;
        }
        #modal-gif, #level-modal-star {
            width: 200px;
            height: 200px;
            border-radius: 10px;
        }
        #modal-close, #level-modal-close {
            background-color: #C9E4F5;
            color: #5A4B6B;
            padding: 10px 20px;
            border-radius: 15px;
            border: none;
            font-size: 18px;
            cursor: pointer;
            transition: background-color 0.3s;
        }
        #modal-close:hover, #level-modal-close:hover {
            background-color: #AED9F0;
        }
        .stats-button {
            background-color: #E8E8F5;
            color: #5A4B6B;
            padding: 8px 16px;
            border-radius: 10px;
            border: 2px solid #C9E4F5;
            transition: transform 0.3s;
        }
        .stats-button:hover {
            transform: scale(1.1);
            background-color: #D4D4F0;
        }
        #next-button {
            display: none;
            background-color: #D4E4D7;
            color: #5A4B6B;
            padding: 10px 20px;
            border-radius: 15px;
            border: none;
            font-size: 18px;
            cursor: pointer;
            transition: background-color 0.3s;
        }
        #next-button:hover {
            background-color: #B7D4BB;
        }
    </style>
</head>
<body class="flex items-center justify-center min-h-screen">
    <div class="game-container max-w-4xl w-full">
        <h1 id="theme" class="text-4xl font-bold text-[#A89EBF] bg-[#C9E4F5] p-4 rounded-lg shadow-md text-center">الموضوع: {{ theme }}</h1>
        <p id="instruction" class="text-2xl text-[#A89EBF] mb-6 text-center">قم بمطابقة الكلمات مع مرادفاتها!</p>
        <div class="flex justify-center space-x-6 mb-6">
            <button id="attempts" class="stats-button">المحاولات: {{ attemptsLeft }}</button>
            <button id="score" class="stats-button">النقاط: {{ score }}</button>
        </div>
        <div class="button-container">
            <div class="word-column">
                {% for word in words %}
                    <button class="word-button" data-word="{{ word }}">{{ word }}</button>
                {% endfor %}
            </div>
            <div class="synonym-column">
                {% for synonym in synonyms %}
                    <button class="synonym-button" data-synonym="{{ synonym }}">{{ synonym }}</button>
                {% endfor %}
            </div>
        </div>
        <div class="mt-6 flex justify-center space-x-4">
            <a href="{{ path('language_selection') }}" class="bg-[#D4E4D7] text-[#5A4B6B] px-6 py-3 rounded-full hover:bg-[#B7D4BB] text-xl font-bold transition duration-300">رجوع</a>
            <button id="next-button" class="text-xl font-bold">التالي</button>
        </div>
    </div>
    <div id="modal">
        <div class="modal-content">
            <p id="modal-message"></p>
            <img id="modal-gif" src="/images/no.gif" class="w-64 h-64">
            <audio id="modal-audio" src="" style="display: none;"></audio>
            <button id="modal-close" class="bg-blue-300 px-4 py-2 mt-4 rounded">إغلاق</button>
        </div>
    </div>
    <div id="level-modal">
        <div class="modal-content">
            <p id="level-modal-message"></p>
            <img id="level-modal-star" src="/images/fun.gif" class="w-64 h-64">
            <audio id="level-modal-audio" src="" style="display: none;"></audio>
            <button id="level-modal-close" class="bg-blue-300 px-4 py-2 mt-4 rounded">رجوع</button>
        </div>
    </div>
    <script>
        let firstSelected = null;
        let firstWord = null;
        let attemptsLeft = {{ attemptsLeft }};
        let attemptsUsedInStage = 3 - attemptsLeft;

        document.querySelectorAll('.word-button, .synonym-button').forEach(button => {
            button.addEventListener('click', () => {
                if (button.classList.contains('matched') || button.disabled) return; // Prevent clicking matched buttons
                if (firstSelected === null) {
                    firstSelected = button;
                    firstWord = button.dataset.word || button.dataset.synonym;
                    button.classList.add('selected');
                } else if (firstSelected !== button) { // Prevent selecting the same button
                    const secondWord = button.dataset.word || button.dataset.synonym;
                    const isWord = button.classList.contains('word-button');
                    firstSelected.classList.remove('selected');
                    submitMatch(firstWord, secondWord, isWord, button);
                }
            });
        });

        document.getElementById('next-button').addEventListener('click', () => {
            fetch('{{ path('game_action') }}', {
                method: 'POST',
                headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                body: `action=next&attemptsLeft=${attemptsLeft}&attemptsUsedInStage=${attemptsUsedInStage}`
            })
            .then(response => response.json())
            .then(data => handleResponse(data))
            .catch(error => {
                console.error('Fetch error:', error);
                showModal('حدث خطأ في الشبكة.', '/images/no.gif', '/audio/incorrect.mp3');
            });
        });

        function submitMatch(firstWord, secondWord, isWord, secondButton) {
            fetch('{{ path('game_action') }}', {
                method: 'POST',
                headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                body: `action=match&firstWord=${encodeURIComponent(firstWord || '')}&secondWord=${encodeURIComponent(secondWord || '')}&isWord=${isWord}&attemptsLeft=${attemptsLeft}&attemptsUsedInStage=${attemptsUsedInStage}`
            })
            .then(response => response.json())
            .then(data => handleResponse(data))
            .catch(error => {
                console.error('Fetch error:', error);
                showModal('حدث خطأ في الشبكة.', '/images/no.gif', '/audio/incorrect.mp3');
            });
        }

        function handleResponse(data) {
            console.log('Response from server:', data);
            if (firstSelected) {
                firstSelected.classList.remove('selected');
            }
            document.getElementById('attempts').textContent = `المحاولات: ${data.attemptsLeft}`;
            document.getElementById('score').textContent = `النقاط: ${data.score}`;

            if (data.showNextButton) {
                document.getElementById('next-button').style.display = 'block';
            } else {
                document.getElementById('next-button').style.display = 'none';
            }

            // Handle flash messages
            if (data.flashMessages && data.flashMessages.success) {
                showModal(data.flashMessages.success, '/images/correct.gif', '/audio/correct.mp3');
            } else if (data.flashMessages && data.flashMessages.error) {
                showModal(data.flashMessages.error, '/images/no.gif', '/audio/incorrect.mp3');
            }

            if (data.status === 'continue') {
                if (data.correctMatch) {
                    firstSelected.classList.add('matched');
                    secondButton.classList.add('matched');
                    firstSelected.disabled = true;
                    secondButton.disabled = true;
                }
                if (data.message) {
                    showModal(data.message, data.correctMatch ? '/images/correct.gif' : '/images/no.gif', data.correctMatch ? '/audio/correct.mp3' : '/audio/incorrect.mp3');
                }
                updateButtons(data.words, data.synonyms);
            } else if (data.status === 'next_theme') {
                document.getElementById('theme').textContent = `الموضوع: ${data.theme}`;
                updateButtons(data.words, data.synonyms);
                if (data.message) {
                    showModal(data.message, data.gif || '/images/correct.gif', data.audio || '/audio/correct.mp3');
                }
                attemptsLeft = data.attemptsLeft;
                attemptsUsedInStage = 0;
            } else if (data.status === 'next_level') {
                showLevelModal(data.message, data.gif || '/images/fun.gif', data.audio || '/audio/correct.mp3');
                setTimeout(() => window.location.reload(), 2000);
            } else if (data.status === 'game_over') {
                showModal(data.message, data.gif || '/images/fun.gif', data.audio || '/audio/correct.mp3');
                setTimeout(() => window.location.href = '{{ path('language_selection') }}', 2000);
            } else if (data.status === 'error') {
                showModal(data.message || 'حدث خطأ.', '/images/no.gif', '/audio/incorrect.mp3');
            }
            firstSelected = null;
            firstWord = null;
        }

        function updateButtons(words, synonyms) {
            const wordButtons = document.querySelectorAll('.word-button');
            const synonymButtons = document.querySelectorAll('.synonym-button');
            wordButtons.forEach((btn, index) => {
                const isMatched = btn.classList.contains('matched');
                btn.textContent = words[index];
                btn.dataset.word = words[index];
                if (!isMatched) {
                    btn.classList.remove('matched', 'selected');
                    btn.disabled = false;
                }
            });
            synonymButtons.forEach((btn, index) => {
                const isMatched = btn.classList.contains('matched');
                btn.textContent = synonyms[index];
                btn.dataset.synonym = synonyms[index];
                if (!isMatched) {
                    btn.classList.remove('matched', 'selected');
                    btn.disabled = false;
                }
            });
        }

        function showModal(message, gif, audioSrc) {
            document.getElementById('modal-message').textContent = message;
            document.getElementById('modal-gif').src = gif;
            const audio = document.getElementById('modal-audio');
            audio.src = audioSrc;
            audio.play().catch(error => console.error('Audio playback error:', error));
            document.getElementById('modal').style.display = 'flex';
        }

        function showLevelModal(message, gif, audioSrc) {
            document.getElementById('level-modal-message').textContent = message;
            document.getElementById('level-modal-star').src = gif;
            const audio = document.getElementById('level-modal-audio');
            audio.src = audioSrc;
            audio.play().catch(error => console.error('Audio playback error:', error));
            document.getElementById('level-modal').style.display = 'flex';
        }

        document.getElementById('modal-close').addEventListener('click', () => {
            document.getElementById('modal').style.display = 'none';
            document.getElementById('modal-audio').pause();
            document.getElementById('modal-audio').currentTime = 0;
        });

        document.getElementById('level-modal-close').addEventListener('click', () => {
            document.getElementById('level-modal').style.display = 'none';
            document.getElementById('level-modal-audio').pause();
            document.getElementById('level-modal-audio').currentTime = 0;
            window.location.href = '{{ path('language_selection') }}';
        });
    </script>
</body>
</html>