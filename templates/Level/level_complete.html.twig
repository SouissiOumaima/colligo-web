{% extends 'base.html.twig' %}

{% block title %}تهانينا! المرحلة كاملة{% endblock %}

{% block stylesheets %}
    <style>
        body {
            margin: 0;
            padding: 0;
            font-family: Arial, sans-serif;
            direction: rtl;
            background: #B7E4C7;
        }
        .container {
            height: 100vh;
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            text-align: center;
        }
        h1 {
            font-size: clamp(24px, 6vw, 48px);
            color: #2A2A2A;
            margin-bottom: 30px;
            text-shadow: 2px 2px 4px rgba(0, 0, 0, 0.2);
        }
        a {
            font-size: clamp(16px, 4vw, 24px);
            color: #4682B4;
            text-decoration: none;
            margin: 10px 0;
            padding: 10px 20px;
            border-radius: 10px;
            background: rgba(255, 255, 255, 0.8);
            box-shadow: 0 5px 10px rgba(0, 0, 0, 0.2);
            transition: transform 0.3s;
        }
        a:hover {
            transform: scale(1.1);
        }
    </style>
{% endblock %}

{% block body %}
    <div class="container">
        <h1>تهانينا! أكملت المرحلة {{ level }}!</h1>
        <a href="{{ path('child_game', {'parentId': child.parentId.parentId, 'childId': child.childId, 'gameIndex': 1}) }}">العب المرحلة التالية</a>
        <a href="{{ path('child_dashboard', {'parentId': child.parentId.parentId, 'childId': child.childId}) }}">العودة إلى الألعاب</a>
    </div>
{% endblock %}