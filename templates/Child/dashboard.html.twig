{% extends 'base.html.twig' %}

{% block title %}لوحة ألعابي الممتعة{% endblock %}

{% block stylesheets %}
    <style>
        body {
            background: linear-gradient(135deg, #FFF3B0, #B7E4C7); /* Yellow to light green */
            font-family: 'Comic Neue', Arial, sans-serif; /* Playful font */
            margin: 0;
            padding: 20px;
            direction: rtl;
            color: #2A2A2A;
        }
        .dashboard-container {
            max-width: 1200px;
            margin: 0 auto;
        }
        /* Profile Section */
        .profile-box {
            display: flex;
            align-items: center;
            justify-content: space-between;
            background: linear-gradient(135deg, #48CAE4, #00B4D8); /* Blue gradient */
            border-radius: 40px;
            padding: 20px;
            margin-bottom: 40px;
            box-shadow: 0 10px 20px rgba(0, 0, 0, 0.2);
            animation: bounceIn 1s ease;
        }
        @keyframes bounceIn {
            0% { transform: scale(0.8); opacity: 0; }
            60% { transform: scale(1.1); opacity: 1; }
            100% { transform: scale(1); }
        }
        .profile-image {
            width: 100px;
            height: 100px;
            border-radius: 50%;
            object-fit: cover;
            border: 5px solid #FFF3B0; /* Yellow border */
            transition: transform 0.3s;
        }
        .profile-image:hover {
            transform: rotate(10deg) scale(1.1);
        }
        .info-grid {
            display: grid;
            grid-template-columns: auto auto;
            gap: 15px;
            align-items: center;
            color: #fff;
            font-size: 20px;
            padding: 0 20px;
        }
        .info-grid .label {
            font-weight: bold;
            text-align: left;
        }
        .info-grid .value {
            text-align: right;
            font-weight: 600;
        }
        .progress-button {
            background-color: #FFD60A; /* Bright yellow */
            color: #2A2A2A;
            font-weight: bold;
            font-size: 18px;
            padding: 15px 30px;
            border-radius: 50px;
            border: 3px solid #FFC107; /* Orange border */
            cursor: pointer;
            box-shadow: 0 6px 12px rgba(0, 0, 0, 0.2);
            transition: transform 0.2s, background-color 0.3s;
        }
        .progress-button:hover {
            background-color: #FFC107;
            transform: scale(1.1) rotate(5deg);
        }
        .gif-image {
            width: 100px;
            height: 100px;
            border-radius: 20px;
            transition: transform 0.3s;
        }
        .gif-image:hover {
            transform: scale(1.2);
        }
        /* Games Section */
        .games-section {
            background-color: #fff;
            border-radius: 40px;
            padding: 25px;
            box-shadow: 0 12px 24px rgba(0, 0, 0, 0.15);
            margin-bottom: 40px;
        }
        .games-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
            gap: 30px;
            padding: 20px;
        }
        .game-container {
            background: linear-gradient(135deg, #95E1D3, #B7E4C7); /* Green gradient */
            border-radius: 50%;
            width: 250px;
            height: 250px;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            box-shadow: 0 8px 16px rgba(0, 0, 0, 0.2);
            transition: transform 0.3s, box-shadow 0.3s;
            text-decoration: none;
            color: inherit;
            position: relative;
            overflow: hidden;
        }
        .game-container:hover {
            transform: scale(1.1) rotate(3deg);
            box-shadow: 0 12px 24px rgba(0, 0, 0, 0.3);
        }
        .game-image {
            width: 250px;
            height: 250px;
            border-radius: 50%;
            object-fit: cover;
            transition: transform 0.3s;
        }
        .game-image:hover {
            transform: scale(1.05);
        }
        .game-name {
            font-size: 24px;
            font-weight: bold;
            color: #2A2A2A;
            text-align: center;
            margin-top: 10px;
            padding: 10px;
            background: rgba(255, 255, 255, 0.7);
            border-radius: 15px;
            width: 100%;
            position: absolute;
            bottom: 10px;
        }
        /* Progress Modal */
        .modal {
            display: none;
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background-color: rgba(0, 0, 0, 0.5);
            justify-content: center;
            align-items: center;
            z-index: 1000;
        }
        .modal-content {
            background: linear-gradient(135deg, #FEE440, #FFD60A); /* Yellow gradient */
            border: 5px solid #00B4D8; /* Blue border */
            border-radius: 30px;
            padding: 30px;
            width: 500px;
            text-align: center;
            box-shadow: 0 12px 30px rgba(0, 0, 0, 0.3);
            animation: popIn 0.5s ease;
        }
        @keyframes popIn {
            0% { transform: scale(0.5); opacity: 0; }
            80% { transform: scale(1.1); opacity: 1; }
            100% { transform: scale(1); }
        }
        .modal-title {
            font-size: 28px;
            font-weight: bold;
            color: #2A2A2A;
            margin-bottom: 20px;
            text-shadow: 2px 2px 4px rgba(0, 0, 0, 0.2);
        }
        .progress-gif {
            width: 350px;
            height: 90px;
            margin: 20px 0;
            border-radius: 15px;
            border: 3px solid #95E1D3;
        }
        .game-progress {
            display: flex;
            justify-content: space-between;
            margin: 15px 0;
            font-size: 20px;
            padding: 12px;
            background: rgba(255, 255, 255, 0.8);
            border-radius: 15px;
            box-shadow: 0 4px 8px rgba(0, 0, 0, 0.1);
            transition: transform 0.2s;
        }
        .game-progress:hover {
            transform: scale(1.03);
        }
        .game-progress .name {
            color: #00B4D8; /* Blue */
            font-weight: bold;
            text-align: right;
        }
        .game-progress .details {
            color: #2A2A2A;
            text-align: left;
        }
        .close-button {
            background-color: #FFD60A;
            color: #2A2A2A;
            font-weight: bold;
            font-size: 18px;
            padding: 15px 30px;
            border-radius: 50px;
            border: 3px solid #FFC107;
            cursor: pointer;
            box-shadow: 0 6px 12px rgba(0, 0, 0, 0.2);
            transition: transform 0.2s, background-color 0.3s;
            margin-top: 20px;
        }
        .close-button:hover {
            background-color: #FFC107;
            transform: scale(1.1) rotate(-5deg);
        }
        /* Responsive Adjustments */
        @media (max-width: 768px) {
            .profile-box {
                flex-direction: column;
                padding: 15px;
                text-align: center;
            }
            .info-grid {
                grid-template-columns: 1fr;
                gap: 10px;
            }
            .games-grid {
                grid-template-columns: 1fr;
            }
            .modal-content {
                width: 90%;
                padding: 20px;
            }
            .game-container {
                width: 200px;
                height: 200px;
            }
            .game-image {
                width: 200px;
                height: 200px;
            }
        }
    </style>
    <link href="https://fonts.googleapis.com/css2?family=Comic+Neue:wght@400;700&display=swap" rel="stylesheet">
{% endblock %}

{% block body %}
    <div class="dashboard-container">
        <section class="profile-box">
            <img src="{{ asset('avatars/' ~ child.avatar ~ '.png') | default('https://via.placeholder.com/100') }}" class="profile-image" alt="Profile Avatar">
            <div class="info-grid">
                <span class="label">الإسم:</span>
                <span class="value">{{ username }}</span>
                <span class="label">اللغة:</span>
                <span class="value">{{ language }}</span>
                <button class="progress-button" onclick="showProgressModal()">تقدّمي</button>
            </div>
            <img src="{{ asset('gifs/welcome.gif') | default('https://via.placeholder.com/100') }}" class="gif-image" alt="Welcome GIF">
        </section>

        <section class="games-section">
            <div class="games-grid">
                {% set gameData = [
                    {'name': 'لعبة الكلمة الدخيلة', 'image': 'jeudedevinette.jpeg', 'index': 1},
                    {'name': 'لعبة الكلمات', 'image': 'draganddrop.png', 'index': 2},
                    {'name': 'لعبة الجمل', 'image': 'fillintheblank.png', 'index': 3},
                    {'name': 'لعبة الصور', 'image': 'imagesgame.jpg', 'index': 4},
                    {'name': 'لعبة المطابقة', 'image': 'wordgame.png', 'index': 5}
                ] %}
                {% for game in gameData %}
                    <a href="{{ path('child_game', {'parentId': child.parentId.parentId, 'childId': child.childId, 'gameIndex': game.index}) }}" class="game-container">
                        <img src="{{ asset('images/' ~ game.image) | default('https://via.placeholder.com/250') }}" class="game-image" alt="Game {{ game.index }}">
                        <div class="game-name">{{ game.name }}</div>
                    </a>
                {% endfor %}
            </div>
        </section>

        <div id="progressModal" class="modal">
            <div class="modal-content">
                <div class="modal-title">تقدّمي في الألعاب</div>
                <img src="{{ asset('gifs/progress.gif') | default('https://via.placeholder.com/50') }}" class="progress-gif" alt="Progress GIF">
                {% for i in 1..5 %}
                    <div class="game-progress">
                        <span class="details">المستوى {{ gameProgress[i] ? gameProgress[i].level : 0 }} - النقاط: {{ gameProgress[i] ? gameProgress[i].score : 0 }}</span>
                        <span class="name">{{ gameData[i-1].name }}:</span>
                    </div>
                {% endfor %}
                <button class="close-button" onclick="closeProgressModal()">إغلاق</button>
            </div>
        </div>
    </div>
{% endblock %}

{% block javascripts %}
    <script>
        function showProgressModal() {
            document.getElementById('progressModal').style.display = 'flex';
        }
        function closeProgressModal() {
            document.getElementById('progressModal').style.display = 'none';
        }
    </script>
{% endblock %}