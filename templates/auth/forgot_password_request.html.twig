{% extends 'base.html.twig' %}

{% block title %}Demande de réinitialisation de mot de passe{% endblock %}

{% block body %}
<style>
    body {
        font-family: 'Poppins', sans-serif;
        display: flex;
        justify-content: center;
        align-items: center;
        min-height: 100vh;
        margin: 0;
        background: #ffffff;
        overflow: hidden;
    }
    
    .verify-container {
        background: #ffffff;
        padding: 60px;
        border-radius: 15px;
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.1);
        max-width: 600px;
        width: 100%;
        text-align: center;
        transform: translateY(20px);
        opacity: 0;
        animation: slideIn 0.5s ease-out forwards;
    }
    
    @keyframes slideIn {
        to {
            transform: translateY(0);
            opacity: 1;
        }
    }
    
    .verify-container h1 {
        font-size: 32px;
        font-weight: 600;
        color: #2d2d2d;
        margin-bottom: 15px;
        letter-spacing: 0.5px;
    }
    
    .verify-container p {
        font-size: 16px;
        color: #6b7280;
        margin-bottom: 30px;
        line-height: 1.6;
    }
    
    .verify-form {
        display: flex;
        flex-direction: column;
        gap: 20px;
    }
    
    .verify-input {
        padding: 12px;
        font-size: 16px;
        border: 2px solid #e5e7eb;
        border-radius: 8px;
        outline: none;
        transition: all 0.3s ease;
        background: #fafafa;
        max-width: 400px;
        width: 100%;
        align-self: center;
    }
    
    .verify-input:focus {
        border-color: #3b82f6;
        background: #ffffff;
        box-shadow: 0 0 0 4px rgba(59, 130, 246, 0.1);
    }
    
    .verify-button {
        background: #FFAE9D;
        color: #2d2d2d;
        padding: 14px 28px;
        font-size: 14px;
        font-weight: 600;
        border: none;
        border-radius: 8px;
        cursor: pointer;
        transition: all 0.3s ease;
        text-transform: uppercase;
        letter-spacing: 1px;
        max-width: 200px;
        align-self: center;
    }
    
    .verify-button:hover {
        background: #ff9b89;
        transform: translateY(-2px);
        box-shadow: 0 5px 15px rgba(255, 174, 157, 0.5);
    }
    
    .verify-button:active {
        transform: translateY(0);
        box-shadow: 0 2px 5px rgba(255, 174, 157, 0.3);
    }
    
    .success-message {
        color: #16a34a;
        font-size: 16px;
        font-weight: 500;
        margin-bottom: 20px;
        background: #dcfce7;
        padding: 10px;
        border-radius: 8px;
    }
    
    .error-message {
        color: #dc2626;
        font-size: 16px;
        font-weight: 500;
        margin-bottom: 20px;
        background: #fee2e2;
        padding: 10px;
        border-radius: 8px;
    }
    
    .login-link {
        font-size: 14px;
        color: #000000;
        text-decoration: none;
        transition: color 0.3s ease;
        align-self: flex-end;
        margin-right: 100px;
    }
    
    .login-link:hover {
        color: #FFAE9D;
        text-decoration: underline;
    }
    
    @media (max-width: 600px) {
        .verify-container {
            padding: 40px;
            margin: 20px;
        }
    
        .verify-container h1 {
            font-size: 26px;
        }
    
        .verify-container p {
            font-size: 14px;
        }
    
        .verify-input,
        .verify-button {
            font-size: 14px;
            padding: 10px;
        }
        
        .login-link {
            font-size: 12px;
            margin-right: 50px;
        }
    }
</style>

<div class="verify-container">
    {% for message in app.flashes('success') %}
        <div class="success-message">{{ message }}</div>
    {% endfor %}
    {% for message in app.flashes('error') %}
        <div class="error-message">{{ message }}</div>
    {% endfor %}

    <h1>Mot de passe oublié</h1>
    <p>Entrez votre email pour recevoir un code de réinitialisation :</p>

    <form method="post" action="{{ path('forgot_password_request') }}" class="verify-form">
        <input type="email" name="email" placeholder="Email" class="verify-input" required>
        <a href="/login" class="login-link">Retour à la connexion</a>
        <button type="submit" class="verify-button">Envoyer</button>
    </form>
</div>
{% endblock %}