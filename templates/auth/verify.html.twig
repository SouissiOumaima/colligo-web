<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Verify Account</title>
    <style>
        body {
            font-family: 'Poppins', sans-serif;
            display: flex;
            justify-content: center;
            align-items: center;
            min-height: 100vh;
            margin: 0;
            overflow: hidden;
        }
        
        .verify-container {
            background: #ffffff;
            padding: 60px;
            border-radius: 15px;
            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.1);
            max-width: 550px;
            width: 100%;
            text-align: center;
            transform: translateY(20px);
            opacity: 0;
            animation: slideIn 0.5s ease-out forwards;
        }
        
        @keyframes slideIn {
            to {
                transform: translateY(0);
                opacity: 1;
            }
        }
        
        .verify-container h1 {
            font-size: 32px;
            font-weight: 600;
            color: #2d2d2d;
            margin-bottom: 15px;
            letter-spacing: 0.5px;
        }
        
        .verify-container p {
            font-size: 16px;
            color: #6b7280;
            margin-bottom: 30px;
            line-height: 1.6;
        }
        
        .verify-form {
            display: flex;
            flex-direction: column;
            gap: 20px;
        }
        
        .verify-input {
            padding: 12px;
            font-size: 16px;
            border: 2px solid #e5e7eb;
            border-radius: 8px;
            outline: none;
            transition: all 0.3s ease;
            background: #fafafa;
            max-width: 350px;
            width: 100%;
            align-self: center;
        }
        
        .verify-input:focus {
            border-color: #3b82f6;
            background: #ffffff;
            box-shadow: 0 0 0 4px rgba(59, 130, 246, 0.1);
        }
        
        .verify-button {
            background: #FFAE9D;
            color: #2d2d2d;
            padding: 10px 20px;
            font-size: 14px;
            font-weight: 600;
            border: none;
            border-radius: 8px;
            cursor: pointer;
            transition: all 0.3s ease;
            text-transform: uppercase;
            letter-spacing: 1px;
            max-width: 150px;
            align-self: center;
        }
        
        .verify-button:hover {
            background: #ff9b89;
            transform: translateY(-2px);
            box-shadow: 0 5px 15px rgba(255, 174, 157, 0.5);
        }
        
        .verify-button:active {
            transform: translateY(0);
            box-shadow: 0 2px 5px rgba(255, 174, 157, 0.3);
        }
        
        .success-message {
            color: #16a34a;
            font-size: 16px;
            font-weight: 500;
            margin-bottom: 20px;
            background: #dcfce7;
            padding: 10px;
            border-radius: 8px;
        }
        
        .error-message {
            color: #dc2626;
            font-size: 16px;
            font-weight: 500;
            margin-bottom: 20px;
            background: #fee2e2;
            padding: 10px;
            border-radius: 8px;
        }
        
        .login-link {
            font-size: 14px;
            color: #000000;
            text-decoration: none;
            transition: color 0.3s ease;
            align-self: flex-end;
            margin-right: 100px;
        }
        
        .login-link:hover {
            color: #FFAE9D;
            text-decoration: underline;
        }
        
        .flash-message {
            display: block;
            opacity: 1;
            transition: opacity 0.5s ease-out;
        }
        
        .flash-message.hidden {
            opacity: 0;
            display: none;
        }
        
        @media (max-width: 600px) {
            .verify-container {
                padding: 40px;
                margin: 20px;
            }
        
            .verify-container h1 {
                font-size: 26px;
            }
        
            .verify-container p {
                font-size: 14px;
            }
        
            .verify-input,
            .verify-button {
                font-size: 14px;
                padding: 10px;
            }
            
            .login-link {
                font-size: 12px;
                margin-right: 50px;
            }
        }
    </style>
</head>
<body>
    <div class="verify-container">
        {% for message in app.flashes('success') %}
            <div class="success-message flash-message">{{ message }}</div>
        {% endfor %}
        {% for message in app.flashes('error') %}
            <div class="error-message flash-message">{{ message }}</div>
        {% endfor %}

        <h1>Vérifier votre compte</h1>
        <p>Un code de vérification a été envoyé à votre email. Veuillez entrer le code ci-dessous :</p>

        {{ form_start(form, {'attr': {'class': 'verify-form'}}) }}
            {{ form_widget(form.code, {'attr': {'placeholder': 'Code de vérification', 'class': 'verify-input'}}) }}
            <a href="/login" class="login-link">Page de connexion</a>
            <input type="hidden" name="token" value="{{ token }}">
            <button type="submit" class="verify-button">VÉRIFIER</button>
        {{ form_end(form) }}
    </div>

</body>
</html>