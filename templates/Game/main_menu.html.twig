{% extends 'base.html.twig' %}

{% block title %}لعبة مطابقة الصور{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link href="https://fonts.googleapis.com/css2?family=Tajawal:wght@400;700&display=swap" rel="stylesheet">
    <style>
        /* Base reset and styling */
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Tajawal', 'Arial', sans-serif;
            direction: rtl;
            overflow: hidden;
            background: linear-gradient(45deg, #00c4b4, #7bed9f, #4a90e2, #a29bfe);
            background-size: 400%;
            animation: gradientShift 15s ease infinite;
        }

        @keyframes gradientShift {
            0% { background-position: 0% 50%; }
            50% { background-position: 100% 50%; }
            100% { background-position: 0% 50%; }
        }

        /* Main container */
        .main-container {
            position: relative;
            width: 100vw;
            height: 100vh;
            display: flex;
            justify-content: center;
            align-items: center;
            overflow: hidden;
        }

        /* Content box */
        .content-box {
            display: flex;
            flex-direction: column;
            align-items: center;
            text-align: center;
            padding: 20px;
            background: rgba(255, 255, 255, 0.95);
            border-radius: 15px;
            box-shadow: 0 15px 30px rgba(0, 0, 0, 0.2);
            animation: slideIn 1s ease-out;
            max-width: 80%;
            width: clamp(250px, 40vw, 450px);
            position: relative;
            z-index: 10;
        }

        @keyframes slideIn {
            from { opacity: 0; transform: translateY(50px); }
            to { opacity: 1; transform: translateY(0); }
        }

        /* Welcome text */
        .welcome-text {
            color: #ff4b5c;
            font-size: clamp(20px, 4vw, 32px);
            font-weight: 700;
            margin-bottom: 15px; /* Added moderate spacing */
            text-shadow: 2px 2px 5px rgba(0, 0, 0, 0.1);
            animation: pulseText 2s infinite;
        }

        @keyframes pulseText {
            0%, 100% { transform: scale(1); }
            50% { transform: scale(1.05); }
        }

        /* Alert/info text */
        .info-text {
            color: #333;
            font-size: clamp(14px, 2.5vw, 20px);
            margin: 8px 0 15px 0; /* Adjusted for moderate spacing */
            background: rgba(255, 235, 59, 0.2);
            padding: 6px 12px;
            border-radius: 8px;
            transition: background 0.3s;
        }

        .info-text:hover {
            background: rgba(255, 235, 59, 0.4);
        }

        /* GIF image */
        .gif-image {
            width: clamp(80px, 25vw, 180px);
            height: auto;
            margin: 15px 0; /* Adjusted for moderate spacing */
            border-radius: 10px;
            box-shadow: 0 8px 15px rgba(0, 0, 0, 0.15);
            transition: transform 0.3s;
        }

        .gif-image:hover {
            transform: scale(1.1) rotate(5deg);
        }

        /* Buttons */
        .button {
            font-size: clamp(14px, 2.5vw, 18px);
            font-weight: 600;
            padding: 12px 25px;
            margin: 8px 0;
            border: none;
            border-radius: 20px;
            cursor: pointer;
            text-decoration: none;
            color: white;
            position: relative;
            overflow: hidden;
            width: clamp(140px, 20vw, 200px);
            transition: transform 0.3s, box-shadow 0.3s;
            z-index: 1;
        }

        .button::before {
            content: '';
            position: absolute;
            top: 0;
            left: -100%;
            width: 100%;
            height: 100%;
            background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.4), transparent);
            transition: left 0.5s;
            z-index: -1;
        }

        .button:hover::before {
            left: 100%;
        }

        .button:hover {
            transform: translateY(-5px);
            box-shadow: 0 10px 20px rgba(0, 0, 0, 0.3);
        }

        .button:disabled {
            background-color: #cccccc;
            cursor: not-allowed;
        }

        .start-button {
            background: linear-gradient(45deg, #28a745, #34d058);
        }

        .start-button:hover:not(:disabled) {
            background: linear-gradient(45deg, #218838, #28a745);
        }

        .back-button {
            background: linear-gradient(45deg, #007bff, #00c4ff);
        }

        .back-button:hover {
            background: linear-gradient(45deg, #0056b3, #007bff);
        }

        /* Button container */
        .button-container {
            display: flex;
            gap: 15px; /* Moderate spacing between buttons */
            justify-content: center;
            margin-top: 15px; /* Moderate spacing above buttons */
        }

        /* Particles canvas */
        #particles {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            z-index: 1;
        }

        /* Responsive design */
        @media (max-width: 768px) {
            .content-box {
                padding: 15px;
                width: 85%;
            }

            .welcome-text {
                font-size: clamp(18px, 5vw, 28px);
            }

            .info-text {
                font-size: clamp(12px, 3.5vw, 16px);
            }

            .button {
                font-size: clamp(12px, 3.5vw, 16px);
                padding: 10px 20px;
                width: clamp(120px, 35vw, 180px);
            }

            .gif-image {
                width: clamp(70px, 30vw, 150px);
            }
        }

        @media (max-width: 480px) {
            .content-box {
                padding: 10px;
            }

            .welcome-text {
                font-size: clamp(16px, 6vw, 24px);
            }

            .info-text {
                font-size: clamp(10px, 4vw, 14px);
            }

            .button {
                font-size: clamp(10px, 4vw, 14px);
                padding: 8px 15px;
                width: clamp(100px, 40vw, 150px);
            }
        }
    </style>
{% endblock %}

{% block body %}
    <canvas id="particles"></canvas>
    <div class="main-container">
        <div class="content-box">
            <div class="welcome-text">
                مرحبا بيك في لعبة الصور
            </div>
            <div class="info-text">
                <span style="margin-left: 10px;">🎮</span> المرحلة: {{ selectedLevel|default(1) }}
            </div>
            
            {% for message in app.flashes('success') %}
                <div class="info-text">{{ message }}</div>
            {% endfor %}
            {% for message in app.flashes('error') %}
                <div class="info-text" style="background: rgba(255, 99, 71, 0.2);">{{ message }}</div>
            {% endfor %}
            {% if isGameComplete %}
                <div class="info-text">لقد أكملت اللعبة! يرجى التواصل مع ولي الأمر لإعادة تعيين اللعبة.</div>
            {% endif %}
            <video class="gif-image" autoplay muted loop playsinline>
                <source src="{{ asset('videos/dentist.mp4') }}" type="video/mp4">
                متصفحك لا يدعم تشغيل الفيديو.
            </video>
            <div class="button-container">
                {% if isGameComplete %}
                    <button class="button start-button" disabled>بدء اللعب</button>
                {% else %}
                    <a href="{{ path('start_game', {'childId': childId, 'parentId': parentId, 'level': selectedLevel}) }}" class="button start-button">بدء اللعب</a>
                {% endif %}
                <a href="{{ path('child_dashboard', {'parentId': parentId, 'childId': childId}) }}" class="button back-button">رجوع</a>
            </div>
        </div>
    </div>
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script>
        document.addEventListener('DOMContentLoaded', () => {
            // Particle animation
            const canvas = document.getElementById('particles');
            const ctx = canvas.getContext('2d');
            canvas.width = window.innerWidth;
            canvas.height = window.innerHeight;

            const particlesArray = [];
            const numberOfParticles = 100;

            class Particle {
                constructor() {
                    this.x = Math.random() * canvas.width;
                    this.y = Math.random() * canvas.height;
                    this.size = Math.random() * 5 + 1;
                    this.speedX = Math.random() * 3 - 1.5;
                    this.speedY = Math.random() * 3 - 1.5;
                    this.color = `hsl(${Math.random() * 360}, 70%, 70%)`;
                }

                update() {
                    this.x += this.speedX;
                    this.y += this.speedY;
                    if (this.size > 0.2) this.size -= 0.05;
                    if (this.x < 0 || this.x > canvas.width) this.speedX *= -1;
                    if (this.y < 0 || this.y > canvas.height) this.speedY *= -1;
                }

                draw() {
                    ctx.fillStyle = this.color;
                    ctx.beginPath();
                    ctx.arc(this.x, this.y, this.size, 0, Math.PI * 2);
                    ctx.fill();
                }
            }

            function init() {
                for (let i = 0; i < numberOfParticles; i++) {
                    particlesArray.push(new Particle());
                }
            }

            function animate() {
                ctx.clearRect(0, 0, canvas.width, canvas.height);
                particlesArray.forEach(particle => {
                    particle.update();
                    particle.draw();
                    if (particle.size <= 0.2) {
                        particlesArray.splice(particlesArray.indexOf(particle), 1);
                        particlesArray.push(new Particle());
                    }
                });
                requestAnimationFrame(animate);
            }

            init();
            animate();

            window.addEventListener('resize', () => {
                canvas.width = window.innerWidth;
                canvas.height = window.innerHeight;
            });

            // Button hover animation
            const buttons = document.querySelectorAll('.button');
            buttons.forEach(button => {
                button.addEventListener('mouseenter', () => {
                    button.style.transform = 'scale(1.1) translateY(-5px)';
                });
                button.addEventListener('mouseleave', () => {
                    button.style.transform = 'scale(1)';
                });
            });

            // Video error handling
            const mascot = document.querySelector('.gif-image');
            mascot.addEventListener('loadeddata', () => {
                console.log('Video loaded.');
            });
            mascot.addEventListener('error', () => {
                console.error('Error loading video. Check the path:', mascot.currentSrc);
            });
        });
    </script>
{% endblock %}