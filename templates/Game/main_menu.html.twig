{% extends 'base.html.twig' %}

{% block title %}لعبة مطابقة الصور{% endblock %}

{% block body %}
    <div class="bg-animation">
        <div class="cloud cloud1"></div>
        <div class="cloud cloud2"></div>
        <div class="cloud cloud3"></div>
        <div class="sun"></div>
        <div class="rainbow"></div>
    </div>

    <div class="container" style="background-color: transparent !important;">
        <header></header>

        <main class="home-content" style="background-color: transparent !important;">
            <div class="welcome-card" style="background-color: transparent !important;">
                <div class="card-content" style="background-color: transparent !important;">
                    <h2 class="section-title">لعبة مطابقة الصور</h2>

                    {% for message in app.flashes('success') %}
                        <div class="alert alert-success">{{ message }}</div>
                    {% endfor %}
                    {% for message in app.flashes('error') %}
                        <div class="alert alert-danger">{{ message }}</div>
                    {% endfor %}

                    {% if isGameComplete %}
                        <p class="alert alert-info">لقد أكملت اللعبة! يرجى التواصل مع ولي الأمر لإعادة تعيين اللعبة.</p>
                    {% endif %}

                    <div class="action-buttons">
                        {% if isGameComplete %}
                            <button class="btn primary-btn" disabled>بدء اللعب</button>
                        {% else %}
                            <a href="{{ path('start_game', {'childId': childId, 'parentId': parentId, 'level': selectedLevel}) }}" class="btn primary-btn">بدء اللعب</a>
                        {% endif %}
                        <a href="{{ path('child_dashboard', {'parentId': parentId, 'childId': childId}) }}" class="btn secondary-btn">رجوع</a>
                    </div>
                </div>

                <div class="mascot-container">
                    <img src="{{ asset('images/hello.gif') }}" alt="صورة متحركة" class="mascot">
                </div>
            </div>
        </main>
    </div>

    <script>
        document.addEventListener('DOMContentLoaded', () => {
            const mascot = document.querySelector('.mascot');
            mascot.addEventListener('load', () => {
                console.log('GIF loaded. Natural dimensions:', mascot.naturalWidth, 'x', mascot.naturalHeight);
            });
            mascot.addEventListener('error', () => {
                console.error('Error loading GIF. Check the path:', mascot.src);
            });
        });
    </script>
{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link rel="stylesheet" href="{{ asset('css/styles.css') }}">
    <link rel="stylesheet" href="{{ asset('css/animations.css') }}">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Cairo:wght@400;600;700&display=swap" rel="stylesheet">
    <style>
        .container {
            display: flex;
            justify-content: center;
            align-items: center;
            min-height: 100vh;
            background-color: transparent !important;
        }
        .home-content {
            display: flex;
            justify-content: center;
            align-items: center;
            flex-direction: column;
            background-color: transparent !important;
        }
        .welcome-card {
            display: flex;
            justify-content: center;
            align-items: center;
            flex-direction: column;
            background-color: transparent !important;
            text-align: center;
        }
        .card-content {
            background-color: transparent !important;
        }
        .section-title {
            font-size: 48px;
            font-family: 'Cairo', sans-serif;
            color: #333;
            margin-bottom: 20px;
            border-bottom: 4px solid #7b61ff;
            padding-bottom: 10px;
        }
        .action-buttons {
            display: flex;
            gap: 15px;
            margin-bottom: 30px;
            justify-content: center;
        }
        .btn {
            padding: 8px 16px;
            font-size: 16px;
            font-family: 'Cairo', sans-serif;
            border: none;
            border-radius: 8px;
            cursor: pointer;
            transition: transform 0.2s;
            text-decoration: none;
        }
        .primary-btn:disabled {
            background-color: #cccccc;
            cursor: not-allowed;
        }
        .primary-btn {
            background-color: #7b61ff;
            color: #fff;
        }
        .secondary-btn {
            background-color: #68d391;
            color: #fff;
        }
        .btn:hover:not(:disabled) {
            transform: scale(1.05);
        }
        .mascot-container {
            display: flex;
            justify-content: center;
            margin-top: 20px;
        }
        .mascot {
            width: 540px;
            height: 180px;
            object-fit: contain;
        }
        .alert-success {
            color: green;
            border: 1px solid green;
            padding: 10px;
            margin-bottom: 10px;
        }
        .alert-danger {
            color: red;
            border: 1px solid red;
            padding: 10px;
            margin-bottom: 10px;
        }
        .alert-info {
            color: #31708f;
            background-color: #d9edf7;
            border: 1px solid #bce8f1;
            padding: 10px;
            margin-bottom: 10px;
            border-radius: 4px;
        }
    </style>
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script src="{{ asset('js/animations.js') }}"></script>
{% endblock %}