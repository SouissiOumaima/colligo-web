{% extends 'base.html.twig' %}

{% block title %}لعبة الكلمة الدخيلة{% endblock %}

{% block stylesheets %}
    <style>
        /* Réinitialisation et style de base */
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Tajawal', 'Arial', sans-serif;
            direction: rtl;
            overflow: hidden;
        }

        /* Conteneur principal */
        .main-container {
            position: relative;
            width: 100vw;
            height: 100vh;
            display: flex;
            justify-content: center;
            align-items: center;
            background: url("{{ asset('images/image.jpg') }}") no-repeat center center;
            background-size: cover;
        }

        /* Boîte de contenu */
        .content-box {
            display: flex;
            flex-direction: column;
            align-items: center;
            text-align: center;
            padding: 30px;
            background: rgba(245, 245, 220, 0.95); /* Beige clair pour enfants */
            border-radius: 20px;
            box-shadow: 0 15px 30px rgba(0, 0, 0, 0.2);
            animation: slideIn 1s ease-out;
            max-width: 90%;
            width: clamp(300px, 80vw, 800px); /* Élargi pour l'agencement horizontal */
            position: relative;
            z-index: 10;
        }

        @keyframes slideIn {
            from { opacity: 0; transform: translateY(50px); }
            to { opacity: 1; transform: translateY(0); }
        }

        /* Boîte de score */
        .score-box {
            background: linear-gradient(45deg, #ffb347, #ffcc33); /* Couleurs chaudes pour enfants */
            color: #333;
            font-weight: bold;
            font-size: clamp(12px, 2vw, 24px);
            padding: 10px 20px;
            border-radius: 10px;
            box-shadow: 0 5px 15px rgba(0, 0, 0, 0.15);
            position: absolute;
            top: 20px;
            right: 20px;
            z-index: 11;
            transition: transform 0.3s;
        }

        .score-box:hover {
            transform: scale(1.05);
        }

        /* Boîte de contenu du jeu */
        .game-content-box {
            display: flex;
            flex-direction: row; /* Agencement horizontal */
            align-items: center;
            justify-content: center;
            gap: 20px;
            flex-wrap: wrap; /* Permet un retour à la ligne si nécessaire */
            width: 100%;
        }

        /* Panneau GIF */
        .gif-pane {
            width: clamp(100px, 20vw, 200px);
            height: clamp(100px, 20vw, 200px);
            display: flex;
            justify-content: center;
            align-items: center;
        }

        .gif-image {
            width: 100%;
            height: 100%;
            display: none;
            object-fit: contain;
            border-radius: 15px;
            box-shadow: 0 10px 20px rgba(0, 0, 0, 0.15);
            transition: transform 0.3s;
        }

        .gif-image:hover {
            transform: scale(1.1);
        }

        /* Texte des mots */
        .word-text {
            color: #ff6b6b; /* Couleur vive pour enfants */
            font-size: clamp(20px, 4vw, 36px);
            font-weight: bold;
            text-align: center;
            margin: 10px 0;
            text-shadow: 2px 2px 4px rgba(0, 0, 0, 0.1);
        }

        /* Conteneur du thème */
        .theme-container {
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            min-width: 150px;
        }

        /* Étiquette et contenu du thème */
        .theme-label {
            color: #4682B4;
            font-size: clamp(14px, 2.5vw, 24px);
            font-weight: bold;
        }

        .theme-content {
            color: #FF7F50;
            font-size: clamp(14px, 2.5vw, 24px);
            font-weight: bold;
            background: rgba(255, 245, 200, 0.7);
            padding: 8px 15px;
            border-radius: 10px;
            box-shadow: 0 5px 10px rgba(0, 0, 0, 0.1);
        }

        /* Boîte des mots */
        .words-box {
            position: relative;
            display: flex;
            gap: 15px;
            flex-wrap: wrap;
            justify-content: center;
            background: rgba(255, 245, 200, 0.7); /* Fond beige clair */
            padding: 15px;
            border-radius: 15px;
            box-shadow: 0 5px 15px rgba(0, 0, 0, 0.1);
            min-width: 200px;
            max-width: 400px;
            overflow: hidden;
        }

        /* Canvas pour les particules dans words-box */
        #words-particles {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            z-index: 1;
        }

        /* Boutons de mots */
        .word-button {
            background: linear-gradient(45deg, #ffd700, #ffa500); /* Couleurs vives pour enfants */
            color: #333;
            font-size: clamp(12px, 2.5vw, 20px);
            font-weight: bold;
            padding: 12px 25px;
            border: none;
            border-radius: 15px;
            cursor: pointer;
            box-shadow: 0 10px 20px rgba(0, 0, 0, 0.2);
            transition: transform 0.3s, box-shadow 0.3s;
            min-width: 100px;
            text-align: center;
            position: relative;
            z-index: 2; /* Au-dessus du canvas */
        }

        .word-button:hover:not(:disabled) {
            transform: scale(1.1);
            box-shadow: 0 0 15px rgba(255, 215, 0, 0.5); /* Effet de lueur pour enfants */
        }

        .word-button.correct {
            background: linear-gradient(45deg, #28a745, #34d058);
        }

        .word-button.incorrect {
            background: linear-gradient(45deg, #dc3545, #ff6b6b);
        }

        .word-button:disabled {
            cursor: not-allowed;
            opacity: 0.6;
        }

        /* Bouton suivant */
        .next-button {
            background: linear-gradient(45deg, #28a745, #34d058);
            color: white;
            font-size: clamp(12px, 2.5vw, 20px);
            font-weight: bold;
            padding: 12px 30px;
            border: none;
            border-radius: 15px;
            cursor: pointer;
            box-shadow: 0 10px 20px rgba(0, 0, 0, 0.2);
            transition: transform 0.3s, box-shadow 0.3s;
            min-width: 120px;
            position: relative;
            z-index: 10;
        }

        .next-button:hover:not(:disabled) {
            transform: scale(1.1);
            box-shadow: 0 0 15px rgba(40, 167, 69, 0.5);
        }

        .next-button:disabled {
            cursor: not-allowed;
            opacity: 0.6;
        }

        /* Animations */
        .animate {
            animation: bounce 0.5s ease;
        }

        @keyframes bounce {
            0% { transform: translateY(0) scale(1); opacity: 1; }
            50% { transform: translateY(-20px) scale(1.2); opacity: 0.5; }
            100% { transform: translateY(0) scale(1); opacity: 1; }
        }

        .animate-incorrect {
            animation: shake 0.5s ease;
        }

        @keyframes shake {
            0% { transform: translateY(0) scale(1); opacity: 1; }
            50% { transform: translateY(20px) scale(1.2); opacity: 0.5; }
            100% { transform: translateY(0) scale(1); opacity: 1; }
        }

        /* Message d'erreur */
        .error-message {
            color: #dc3545;
            font-size: clamp(12px, 2.5vw, 20px);
            text-align: center;
            margin: 10px 0;
            display: none;
            width: 100%;
        }

        /* Responsive design */
        @media (max-width: 768px) {
            .content-box {
                padding: 20px;
                width: 95%;
            }

            .game-content-box {
                flex-direction: column; /* Retour à la colonne pour petits écrans */
                gap: 15px;
            }

            .word-text {
                font-size: clamp(18px, 5vw, 32px);
            }

            .theme-label, .theme-content {
                font-size: clamp(12px, 3vw, 20px);
            }

            .word-button {
                font-size: clamp(10px, 3vw, 18px);
                padding: 10px 20px;
                min-width: 80px;
            }

            .next-button {
                font-size: clamp(10px, 3vw, 18px);
                padding: 10px 25px;
            }

            .gif-pane {
                width: clamp(80px, 25vw, 150px);
                height: clamp(80px, 25vw, 150px);
            }
        }

        @media (max-width: 480px) {
            .content-box {
                padding: 15px;
            }

            .word-text {
                font-size: clamp(16px, 6vw, 28px);
            }

            .theme-label, .theme-content {
                font-size: clamp(10px, 4vw, 18px);
            }

            .word-button {
                font-size: clamp(10px, 4vw, 16px);
                padding: 8px 15px;
                min-width: 70px;
            }

            .next-button {
                font-size: clamp(10px, 4vw, 16px);
                padding: 8px 20px;
            }
        }
    </style>
    <link href="https://fonts.googleapis.com/css2?family=Tajawal:wght@400;700&display=swap" rel="stylesheet">
{% endblock %}

{% block body %}
    <div class="main-container">
        <div class="content-box">
            <div class="score-box" id="score-text">النقاط: {{ score|default(0) }}/25</div>
            <div class="game-content-box">
                <div class="gif-pane">
                    <img src="{{ asset('gifs/success.gif') }}" class="gif-image" id="correct-gif" alt="نجاح">
                    <img src="{{ asset('gifs/failar.gif') }}" class="gif-image" id="incorrect-gif" alt="فشل">
                </div>
                <div class="word-text" id="word-text">{{ word_text|default('طلّع الكلمة الدخيلة .')|e }}</div>
                <div class="error-message" id="error-message"></div>
                <div class="theme-container">
                    <div class="theme-label">الموضوع</div>
                    <div class="theme-content" id="theme-content">{{ theme|default('')|e }}</div>
                </div>
                <div class="words-box" id="words-box">
                    <canvas id="words-particles"></canvas>
                    {% for word in current_lot|default([]) %}
                        <button class="word-button" data-word="{{ word|e('html_attr') }}">{{ word|e }}</button>
                    {% endfor %}
                </div>
                <button class="next-button" id="next-button" disabled>الّي بعدو</button>
            </div>
        </div>
    </div>
{% endblock %}

{% block javascripts %}
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            // Particules pour la boîte des mots
            const canvas = document.getElementById('words-particles');
            const wordsBox = document.getElementById('words-box');
            const ctx = canvas.getContext('2d');

            function resizeCanvas() {
                canvas.width = wordsBox.offsetWidth;
                canvas.height = wordsBox.offsetHeight;
            }

            resizeCanvas();
            window.addEventListener('resize', resizeCanvas);

            const particlesArray = [];
            const numberOfParticles = 50; // Réduit pour performances

            class Particle {
                constructor() {
                    this.x = Math.random() * canvas.width;
                    this.y = Math.random() * canvas.height;
                    this.size = Math.random() * 3 + 1;
                    this.speedX = Math.random() * 2 - 1;
                    this.speedY = Math.random() * 2 - 1;
                    this.color = `hsl(${Math.random() * 60 + 30}, 70%, 70%)`; // Nuances beiges et chaudes
                }

                update() {
                    this.x += this.speedX;
                    this.y += this.speedY;
                    if (this.size > 0.2) this.size -= 0.05;
                    if (this.x < 0 || this.x > canvas.width) this.speedX *= -1;
                    if (this.y < 0 || this.y > canvas.height) this.speedY *= -1;
                }

                draw() {
                    ctx.fillStyle = this.color;
                    ctx.beginPath();
                    ctx.arc(this.x, this.y, this.size, 0, Math.PI * 2);
                    ctx.fill();
                }
            }

            function init() {
                particlesArray.length = 0;
                for (let i = 0; i < numberOfParticles; i++) {
                    particlesArray.push(new Particle());
                }
            }

            function animate() {
                ctx.clearRect(0, 0, canvas.width, canvas.height);
                particlesArray.forEach(particle => {
                    particle.update();
                    particle.draw();
                    if (particle.size <= 0.2) {
                        particlesArray.splice(particlesArray.indexOf(particle), 1);
                        particlesArray.push(new Particle());
                    }
                });
                requestAnimationFrame(animate);
            }

            init();
            animate();

            // Logique de jeu existante
            console.log('DOM fully loaded');

            const initialWordButtons = document.querySelectorAll('.word-button');
            console.log('Initial word buttons found:', initialWordButtons.length);

            const gameState = {
                attempts: Number("{{ attempts|default(3)|e('js') }}") || 3,
                incorrectAttempts: Number("{{ incorrectAttempts|default(0)|e('js') }}") || 0,
                successfulLots: Number("{{ successful_lots|default(0)|e('js') }}") || 0,
                maxAttempts: 3
            };

            const urls = {
                check: "{{ path('guessing_game_check', {'parentId': child.parentId.parentId, 'childId': child.childId})|e('js') }}",
                nextLot: "{{ path('guessing_game_next_lot', {'parentId': child.parentId.parentId, 'childId': child.childId})|e('js') }}",
                levelComplete: "{{ path('level_complete', {'parentId': child.parentId.parentId, 'childId': child.childId})|e('js') }}"
            };
            console.log('Generated URLs:', urls);

            function attachWordButtonListeners() {
                const wordButtons = document.querySelectorAll('.word-button');
                console.log('Attaching listeners to word buttons:', wordButtons.length);
                wordButtons.forEach(button => {
                    button.removeEventListener('click', handleWordClickWrapper);
                    button.addEventListener('click', handleWordClickWrapper);
                });
            }

            function handleWordClickWrapper(event) {
                const button = event.currentTarget;
                const word = button.dataset.word;
                handleWordClick(word, button);
            }

            attachWordButtonListeners();

            function handleWordClick(word, button) {
                console.log('Word clicked:', word);
                fetch(urls.check, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ word: word })
                })
                .then(response => {
                    console.log('Response status:', response.status);
                    if (!response.ok) {
                        throw new Error(`Network response was not ok: ${response.status}`);
                    }
                    return response.json();
                })
                .then(data => {
                    console.log('Response data:', data);
                    const wordText = document.getElementById('word-text');
                    const correctGif = document.getElementById('correct-gif');
                    const incorrectGif = document.getElementById('incorrect-gif');
                    const nextButton = document.getElementById('next-button');
                    const errorMessage = document.getElementById('error-message');

                    errorMessage.style.display = 'none';

                    if (data.error) {
                        errorMessage.textContent = data.error;
                        errorMessage.style.display = 'block';
                        return;
                    }

                    if (data.isCorrect) {
                        button.classList.add('correct');
                        wordText.textContent = 'صحّيت !';
                        wordText.classList.add('animate');
                        correctGif.style.display = 'block';
                        incorrectGif.style.display = 'none';
                        nextButton.disabled = false;
                        disableWordButtons();
                        gameState.successfulLots = data.successfulLots;
                        if (data.levelUp) {
                            setTimeout(() => {
                                console.log('Redirecting to level complete');
                                window.location.href = urls.levelComplete;
                            }, 2000);
                        }
                    } else {
                        gameState.attempts = data.attempts;
                        gameState.incorrectAttempts++;
                        button.classList.add('incorrect');
                        if (gameState.attempts > 0) {
                            wordText.textContent = `ميسالش عاود المحاولة . (بقي ${gameState.attempts} محاولات)`;
                            wordText.classList.add('animate-incorrect');
                            incorrectGif.style.display = 'block';
                            correctGif.style.display = 'none';
                        } else {
                            wordText.textContent = 'كملّت محاولاتك الكل تعدّا للجملة اللي بعد.';
                            wordText.classList.add('animate-incorrect');
                            incorrectGif.style.display = 'block';
                            correctGif.style.display = 'none';
                            nextButton.disabled = false;
                            disableWordButtons();
                        }
                    }
                    document.getElementById('score-text').textContent = `النقاط: ${data.score}/25`;
                    setTimeout(() => wordText.classList.remove('animate', 'animate-incorrect'), 500);
                })
                .catch(error => {
                    const errorMessage = document.getElementById('error-message');
                    errorMessage.textContent = 'حدث خطأ، حاول مرة أخرى.';
                    errorMessage.style.display = 'block';
                    console.error('Fetch error:', error);
                });
            }

            document.getElementById('next-button').addEventListener('click', handleNextLot);

            function handleNextLot() {
                console.log('Next lot clicked');
                fetch(urls.nextLot, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' }
                })
                .then(response => {
                    console.log('Next lot response status:', response.status);
                    if (!response.ok) {
                        throw new Error(`Network response was not ok: ${response.status}`);
                    }
                    return response.json();
                })
                .then(data => {
                    console.log('Next lot response data:', data);
                    if (data.error) {
                        document.getElementById('error-message').textContent = data.error;
                        document.getElementById('error-message').style.display = 'block';
                        return;
                    }

                    gameState.attempts = gameState.maxAttempts;
                    const wordText = document.getElementById('word-text');
                    const themeContent = document.getElementById('theme-content');
                    const scoreText = document.getElementById('score-text');
                    const correctGif = document.getElementById('correct-gif');
                    const incorrectGif = document.getElementById('incorrect-gif');
                    const nextButton = document.getElementById('next-button');
                    const wordsBox = document.getElementById('words-box');

                    wordText.textContent = 'طلّع الكلمة الدخيلة .';
                    themeContent.textContent = data.theme;
                    scoreText.textContent = `النقاط: ${data.score}/25`;
                    correctGif.style.display = 'none';
                    incorrectGif.style.display = 'none';
                    nextButton.disabled = true;
                    document.getElementById('error-message').style.display = 'none';

                    wordsBox.innerHTML = '<canvas id="words-particles"></canvas>';
                    data.currentLot.forEach(word => {
                        const button = document.createElement('button');
                        button.className = 'word-button';
                        button.textContent = word;
                        button.dataset.word = word;
                        wordsBox.appendChild(button);
                    });

                    // Réinitialiser le canvas après mise à jour
                    const newCanvas = document.getElementById('words-particles');
                    const newCtx = newCanvas.getContext('2d');
                    newCanvas.width = wordsBox.offsetWidth;
                    newCanvas.height = wordsBox.offsetHeight;
                    particlesArray.length = 0;
                    init();
                    animate();

                    attachWordButtonListeners();
                })
                .catch(error => {
                    const errorMessage = document.getElementById('error-message');
                    errorMessage.textContent = 'حدث خطأ، حاول مرة أخرى.';
                    errorMessage.style.display = 'block';
                    console.error('Fetch error:', error);
                });
            }

            function disableWordButtons() {
                document.querySelectorAll('.word-button').forEach(button => {
                    button.disabled = true;
                });
            }
        });
    </script>
{% endblock %}