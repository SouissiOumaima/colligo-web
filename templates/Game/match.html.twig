{% extends 'base.html.twig' %}

{% block title %}لعبة التطابق{% endblock %}

{% block body %}
    <div class="game-container">

        {% if app.flashes('error') %}
            <div class="alert alert-danger" role="alert">
                {% for message in app.flashes('error') %}
                    <p>{{ message }}</p>
                {% endfor %}
            </div>
        {% endif %}

        {% if theme %}
            <h2>الموضوع: {{ theme.name }} (المستوى: {% if current_level == 1 %}سهل{% elseif current_level == 2 %}متوسط{% elseif current_level == 3 %}صعيب{% endif %})</h2>
            <div class="stats-container">
                <button class="stats-button tries-button" disabled>
                    المحاولات الباقية: <span id="tries-left">3</span>
                </button>
                <button class="stats-button score-button" disabled>
                    النقاط: <span id="score">{{ cumulative_score }}</span>
                </button>
            </div>
            <div class="instruction-text">
                <h2>إختار الكلمة ومرادفها الصحيح</h2>
            </div>
            <div class="pair-list" role="list" aria-label="قايمة الكلمات والمرادفات">
                <div class="words-container">
                    <h3>الكلمات</h3>
                    {% for word in words %}
                        <div class="word" data-id="{{ word.id }}" role="button" aria-label="كلمة للتطابق: {{ word.word }} (ID: {{ word.id }})" tabindex="0">{{ word.word }}</div>
                    {% endfor %}
                </div>
                <div class="synonyms-container">
                    <h3>المرادفات</h3>
                    {% for synonym in synonyms %}
                        <div class="synonym" data-id="{{ synonym.id }}" role="button" aria-label="مرادف للتطابق: {{ synonym.synonym }} (ID: {{ synonym.id }})" tabindex="0">{{ synonym.synonym }}</div>
                    {% endfor %}
                </div>
            </div>
            <div id="message" class="alert" role="status" aria-live="polite"></div>
            <div class="button-container">
                <a href="{{ path('game_match', {'childId': child_id}) }}" class="stats-button exit-button">نخرج</a>
            </div>

            <!-- Audio Elements -->
            <audio id="correctAudio" src="/sounds/correct1.mp3"></audio>
            <audio id="incorrectAudio" src="/sounds/incorrect1.mp3"></audio>

            <!-- Failure Modal -->
            <div id="failureModal" class="modal">
                <div class="modal-content">
                    <span class="close">×</span>
                    <h2>ميسالش عاود مرة أخرى</h2>
                    <p>بدّيت تتحسّن ! شد صحيح ! 💫</p>
                    <img src="/Gifs/no1.gif" alt="Failure animation" class="modal-gif">
                    <button id="retryButton" class="stats-button">نجرّب مرّة أخرى</button>
                </div>
            </div>

            <!-- Success Modal -->
            <div id="successModal" class="modal">
                <div class="modal-content">
                    <span class="close">×</span>
                    <h2>برافو عليك!</h2>
                    <p>يعطيك الصحة على المجهود ! نعدّيو للي بعدو ! 🎉</p>
                    <img src="/Gifs/fun.gif" alt="Success animation" class="modal-gif">
                    <p id="nextInfo"></p>
                    <button id="nextButton" class="stats-button">نكمّل</button>
                </div>
            </div>
        {% else %}
            <div class="alert alert-warning" role="alert">
                <p>لا يوجد مواضيع متاحة في هذا المستوى. حاول مستوى آخر أو تواصل مع المسؤول.</p>
                <a href="{{ path('game_match', {'childId': child_id}) }}" class="stats-button">نجرّب ثاني</a>
                <a href="{{ path('game_match', {'childId': child_id}) }}" class="stats-button exit-button">نخرج</a>
            </div>
        {% endif %}
    </div>

    <style>
        body {
            background: linear-gradient(135deg, #e0f7fa 0%, #f3e5f5 100%); /* Mint green to lavender gradient */
            font-family: 'Comic Neue', cursive; /* Playful yet readable font */
            margin: 0;
            padding: 0;
            overflow-x: hidden;
        }

        .game-container {
            background: url('https://www.transparenttextures.com/patterns/rain.png'), rgba(255, 255, 255, 0.9); /* Rain pattern for a magical feel */
            border: 6px solid #ffb6c1; /* Lighter pink border */
            border-radius: 25px;
            padding: 30px;
            box-shadow: 0 8px 16px rgba(0, 0, 0, 0.1);
            animation: floatIn 0.9s ease;
            margin: 30px auto;
            max-width: 900px;
            text-align: center;
            position: relative;
            overflow: hidden;
        }

        @keyframes floatIn {
            0% { transform: translateY(20px); opacity: 0; }
            100% { transform: translateY(0); opacity: 1; }
        }

        h1 {
            color: #ffb6c1; /* Lighter pink */
            font-size: 2.5rem;
            margin-bottom: 10px;
            text-shadow: 1px 1px 4px rgba(255, 182, 193, 0.3); /* Adjusted shadow */
        }

        h2 {
            color: #80deea; /* Light cyan */
            font-size: 1.8rem;
            margin: 10px 0;
        }

        h3 {
            color: #80deea; /* Light cyan */
            font-size: 1.5rem;
            margin-bottom: 15px;
        }

        .stats-container {
            display: flex;
            justify-content: center;
            gap: 20px;
            margin: 15px 0;
        }

        .stats-button {
            background: #F4CFDF; /* Solid color */
            color: #333;
            padding: 12px 25px;
            border-radius: 15px;
            border: none;
            transition: transform 0.3s ease, box-shadow 0.3s ease;
            cursor: pointer;
            text-decoration: none;
            display: inline-block;
            margin: 8px;
            font-size: 1.1rem;
            box-shadow: 0 4px 12px rgba(244, 207, 223, 0.3);
        }

        .stats-button:hover {
            transform: scale(1.1);
            box-shadow: 0 6px 16px rgba(244, 207, 223, 0.4);
        }

        .stats-button:disabled {
            background: #e0e0e0;
            cursor: not-allowed;
            box-shadow: none;
        }

        .tries-button {
            background: #fbdaba; /* Light beige */
        }

        .tries-button:hover {
            box-shadow: 0 6px 16px rgba(251, 218, 186, 0.4); /* Adjusted shadow for light beige */
        }

        .score-button {
            background: #fbdaba; /* Light beige */
        }

        .score-button:hover {
            box-shadow: 0 6px 16px rgba(251, 218, 186, 0.4); /* Adjusted shadow for light beige */
        }

        .instruction-text {
            margin: 15px 0;
            padding: 10px;
            border-radius: 15px;
            background: rgba(255, 255, 255, 0.8);
            border: 2px dashed #ffb6c1; /* Lighter pink dashed border */
        }

        .instruction-text h2 {
            color: #f0dabe; /* Nouvelle couleur appliquée */
            font-size: 1.8rem;
            margin: 0;
        }

        .pair-list {
            margin: 25px 0;
            padding: 15px;
            border-radius: 20px;
            background: rgba(255, 255, 255, 0.8);
            border: 2px dashed #ffb6c1; /* Lighter pink dashed border */
            display: flex;
            justify-content: space-between;
            gap: 20px;
        }

        .words-container, .synonyms-container {
            display: inline-block;
            vertical-align: top;
            width: 45%;
            margin: 0 2.5%;
            padding: 15px;
            border-radius: 15px;
            background: rgba(255, 255, 255, 0.9);
            border: 2px dashed #ffb6c1;
        }

        .words-container h3, .synonyms-container h3 {
            color: #80deea;
            font-size: 1.5rem;
            margin-bottom: 10px;
        }

        .word, .synonym {
            padding: 15px 25px;
            margin: 10px 0;
            background: #F4CFDF; /* Solid color */
            color: #333;
            cursor: pointer;
            transition: transform 0.3s ease, box-shadow 0.3s ease, background 0.3s ease;
            font-size: 1.2rem;
            min-width: 150px;
            text-align: center;
            position: relative;
            box-shadow: 0 4px 10px rgba(244, 207, 223, 0.2);
        }

        .word::before, .synonym::before {
            content: "🦋"; /* Unicode butterfly */
            position: absolute;
            top: 5px;
            left: 5px;
            font-size: 18px;
            color: #80deea; /* Light cyan butterfly */
            opacity: 0; /* Initially hidden */
            transition: opacity 0.3s ease;
        }

        .word::after, .synonym::after {
            content: "🦋"; /* Unicode butterfly */
            position: absolute;
            bottom: 5px;
            right: 5px;
            font-size: 18px;
            color: #80deea; /* Light cyan butterfly */
            opacity: 0; /* Initially hidden */
            transition: opacity 0.3s ease;
        }

        .word.selected::before, .synonym.selected::before,
        .word.selected::after, .synonym.selected::after {
            opacity: 1; /* Show butterflies on click */
            animation: flutter 1.5s infinite ease-in-out;
        }

        .word.disabled::before, .synonym.disabled::before,
        .word.disabled::after, .synonym.disabled::after {
            opacity: 1; /* Keep butterflies visible for correct pairs */
            animation: flutter 1.5s infinite ease-in-out;
        }

        @keyframes flutter {
            0%, 100% { transform: translateY(0) rotate(0deg); }
            50% { transform: translateY(-5px) rotate(10deg); }
        }

        .word:hover, .synonym:hover {
            transform: scale(1.1) rotate(5deg);
            box-shadow: 0 6px 15px rgba(244, 207, 223, 0.3);
        }

        .word:focus, .synonym:focus {
            outline: none;
            box-shadow: 0 0 0 4px rgba(255, 182, 193, 0.4); /* Adjusted to lighter pink */
        }

        .word.selected, .synonym.selected {
            background: linear-gradient(145deg, #b2dfdb, #fff9c4); /* Mint to soft yellow gradient */
            transform: scale(1.05);
        }

        .word.disabled, .synonym.disabled {
            background: linear-gradient(145deg, #ffdab9, #80deea); /* Gradient from image for correct pairs */
            cursor: not-allowed;
            pointer-events: none; /* Prevent further interaction */
            box-shadow: 0 4px 10px rgba(255, 218, 185, 0.2); /* Adjusted shadow to match gradient */
        }

        .exit-button {
            background: #e0e0e0; /* Light grey as requested */
            border: none;
        }

        .exit-button:hover {
            background: #d0d0d0; /* Slightly darker grey for hover effect */
            box-shadow: 0 6px 16px rgba(128, 128, 128, 0.4); /* Grey shadow for consistency */
        }

        .button-container {
            margin-top: 30px;
        }

        .alert {
            margin-top: 20px;
            padding: 10px;
            border-radius: 10px;
            font-weight: bold;
            transition: opacity 0.3s ease;
        }

        .alert.success {
            background: transparent; /* Remove green background */
            color: #1b5e20;
        }

        .alert.error {
            background: transparent; /* Remove light coral background */
            color: #bf360c;
        }

        .alert-warning {
            background: #ce93d8; /* Lavender */
            color: #4a148c;
            border: 1px solid #ab47bc;
            padding: 15px;
            border-radius: 10px;
        }

        /* Modal Styles */
        .modal {
            display: none;
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(0, 0, 0, 0.5);
            z-index: 1000;
            animation: fadeIn 0.3s ease;
        }

        @keyframes fadeIn {
            from { opacity: 0; }
            to { opacity: 1; }
        }

        .modal-content {
            background: linear-gradient(145deg, #ffffff, #f5f5f5);
            margin: 15% auto;
            padding: 25px;
            border: 4px solid #ce93d8; /* Lavender border */
            border-radius: 20px;
            width: 90%;
            max-width: 450px;
            text-align: center;
            box-shadow: 0 8px 16px rgba(0, 0, 0, 0.2);
            animation: slideIn 0.5s ease;
        }

        #successModal .modal-content {
            position: absolute;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
            margin: 0; /* Override the default margin to center vertically */
        }

        #failureModal .modal-content {
            position: absolute;
            top: 10%; /* Positionne le modal plus haut */
            left: 50%;
            transform: translate(-50%, 0); /* Centre horizontalement sans décalage vertical */
            margin: 0; /* Supprime la marge par défaut */
            padding: 25px;
            border: 4px solid #ce93d8; /* Lavender border */
            border-radius: 20px;
            width: 90%;
            max-width: 450px;
            text-align: center;
            box-shadow: 0 8px 16px rgba(0, 0, 0, 0.2);
            animation: slideInFailure 0.5s ease; /* Animation spécifique pour l'échec */
        }

        @keyframes slideIn {
            from { transform: translate(-50%, -60%); opacity: 0; } /* Animation pour le succès */
            to { transform: translate(-50%, -50%); opacity: 1; }
        }

        @keyframes slideInFailure {
            from { transform: translate(-50%, -20%); opacity: 0; } /* Animation pour l'échec, commence plus haut */
            to { transform: translate(-50%, 0); opacity: 1; }
        }

        .modal-content h2 {
            color: #ffb6c1; /* Lighter pink */
            margin-bottom: 15px;
        }

        .modal-content p {
            color: #333;
            font-size: 1.1rem;
        }

        .modal-gif {
            max-width: 100%;
            height: auto;
            margin: 15px 0;
        }

        .close {
            color: #ffb6c1; /* Lighter pink close button */
            float: right;
            font-size: 32px;
            font-weight: bold;
            cursor: pointer;
            transition: color 0.3s ease;
        }

        .close:hover,
        .close:focus {
            color: #ff5722; /* Orange on hover */
        }
    </style>

    {% if theme %}
        <script>
            document.addEventListener('DOMContentLoaded', () => {
                const words = document.querySelectorAll('.word');
                const synonyms = document.querySelectorAll('.synonym');
                const messageDiv = document.getElementById('message');
                const triesLeftSpan = document.getElementById('tries-left');
                const scoreSpan = document.getElementById('score');
                let selectedWord = null;
                let selectedSynonym = null;
                let score = {{ cumulative_score|default(0) }};
                let correctPairs = new Set();
                const startTime = Date.now();
                const childId = {{ child_id|json_encode|raw }};
                const failureModal = document.getElementById('failureModal');
                const successModal = document.getElementById('successModal');
                const retryButton = document.getElementById('retryButton');
                const nextButton = document.getElementById('nextButton');
                const nextInfo = document.getElementById('nextInfo');
                const correctAudio = document.getElementById('correctAudio');
                const incorrectAudio = document.getElementById('incorrectAudio');

                const handleSelection = (element, type) => {
                    if (element.classList.contains('disabled')) return;
                    if (type === 'word') {
                        if (selectedWord) selectedWord.classList.remove('selected');
                        selectedWord = element;
                    } else {
                        if (selectedSynonym) selectedSynonym.classList.remove('selected');
                        selectedSynonym = element;
                    }
                    element.classList.add('selected');
                    if (selectedWord && selectedSynonym && selectedWord.parentElement.classList.contains('words-container') && selectedSynonym.parentElement.classList.contains('synonyms-container')) {
                        checkPair();
                    }
                };

                words.forEach(word => {
                    word.addEventListener('click', () => handleSelection(word, 'word'));
                    word.addEventListener('keydown', (e) => {
                        if (e.key === 'Enter' || e.key === ' ') {
                            e.preventDefault();
                            handleSelection(word, 'word');
                        }
                    });
                });

                synonyms.forEach(synonym => {
                    synonym.addEventListener('click', () => handleSelection(synonym, 'synonym'));
                    synonym.addEventListener('keydown', (e) => {
                        if (e.key === 'Enter' || e.key === ' ') {
                            e.preventDefault();
                            handleSelection(synonym, 'synonym');
                        }
                    });
                });

                function checkPair() {
                    if (selectedWord && selectedSynonym) {
                        fetch('{{ path('game_match_check', {'childId': child_id}) }}', {
                            method: 'POST',
                            headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                            body: `wordId=${selectedWord.dataset.id}&synonymId=${selectedSynonym.dataset.id}`
                        })
                        .then(response => response.json())
                        .then(data => {
                            console.log('Response from checkMatch:', data); // Log pour débogage
                            messageDiv.className = 'alert ' + (data.success ? 'success' : 'error');
                            triesLeftSpan.textContent = data.tries_left;

                            if (data.success) {
                                correctAudio.play();
                                selectedWord.classList.add('disabled');
                                selectedSynonym.classList.add('disabled');
                                selectedWord.classList.remove('selected');
                                selectedSynonym.classList.remove('selected');
                                correctPairs.add(selectedWord.dataset.id);

                                messageDiv.textContent = 'محاولة باهية ! نكملو المغامرة ! 🌟';
                            } else {
                                incorrectAudio.play();
                                messageDiv.textContent = 'عاود المرة الجاية، تنجم تعملها ! 🌟';
                            }

                            if (data.tries_left === 0 && !data.success) {
                                failureModal.style.display = 'block';
                            }

                            if (correctPairs.size === {{ words|length }}) {
                                const timeElapsed = Math.round((Date.now() - startTime) / 1000);
                                const nbTries = 3 - data.tries_left; // Calculer le nombre d'essais ratés
                                fetch('{{ path('game_match_complete', {'childId': child_id}) }}', {
                                    method: 'POST',
                                    headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                                    body: `themeId={{ theme.id }}&gameId={{ game_id }}&nbTries=${nbTries}&time=${timeElapsed}&allCorrect=${correctPairs.size === {{ words|length }} ? 'true' : 'false'}`
                                })
                                .then(response => response.json())
                                .then(data => {
                                    console.log('Response from completeTheme:', data); // Log pour débogage
                                    if (data.success) {
                                        score = data.score || 0;
                                        scoreSpan.textContent = score;
                                        successModal.style.display = 'block';
                                        if (data.nextLevel) {
                                            nextInfo.textContent = `بش تنتقل للمستوى ${data.nextLevel}، برافو!`;
                                        } else if (data.nextThemeId) {
                                            nextInfo.textContent = '';
                                        }
                                    } else if (data.repeat) {
                                        failureModal.style.display = 'block';
                                    }
                                })
                                .catch(error => {
                                    console.error('Error in completeTheme:', error);
                                    messageDiv.textContent = 'فيه مشكل في التقدّم، سامحني!';
                                    messageDiv.className = 'alert error';
                                });
                            }

                            selectedWord.classList.remove('selected');
                            selectedSynonym.classList.remove('selected');
                            selectedWord = null;
                            selectedSynonym = null;
                        })
                        .catch(error => {
                            console.error('Error in checkMatch:', error);
                            messageDiv.textContent = 'فيه مشكل في التأكّد، جرب ثاني!';
                            messageDiv.className = 'alert error';
                            if (selectedWord) selectedWord.classList.remove('selected');
                            if (selectedSynonym) selectedSynonym.classList.remove('selected');
                            selectedWord = null;
                            selectedSynonym = null;
                        });
                    }
                }

                document.querySelectorAll('.close').forEach(close => {
                    close.addEventListener('click', () => {
                        failureModal.style.display = 'none';
                        successModal.style.display = 'none';
                    });
                });

                retryButton.addEventListener('click', () => {
                    failureModal.style.display = 'none';
                    window.location.href = '{{ path('game_match', {'childId': child_id}) }}';
                });

                nextButton.addEventListener('click', () => {
                    successModal.style.display = 'none';
                    window.location.href = '{{ path('game_match', {'childId': child_id}) }}';
                });

                window.addEventListener('click', (event) => {
                    if (event.target === failureModal || event.target === successModal) {
                        failureModal.style.display = 'none';
                        successModal.style.display = 'none';
                    }
                });
            });
        </script>
    {% endif %}
{% endblock %}