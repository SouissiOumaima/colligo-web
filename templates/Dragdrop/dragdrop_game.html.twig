{% extends 'base.html.twig' %}

{% block body %}
    <div id="game-container" style="font-family: 'Baloo Bhaijaan 2', 'Comic Neue', cursive, sans-serif; max-width: 900px; margin: 0 auto; padding: 30px; background: linear-gradient(to right, #ffd3a5, #fd6585); border-radius: 25px; box-shadow: 0 8px 16px rgba(0, 0, 0, 0.2);">
        <h1 style="text-align: center; color: #ffffff; font-size: 40px; text-shadow: 2px 2px #fa7268; margin-bottom: 25px;">
            🧩 لعبة ترتيب الكلمات السحرية
        </h1>

        <div style="text-align: center; margin-bottom: 25px;">
            <img src="/images/mascot.png" alt="Game Icon" style="border-radius: 50%; border: 6px solid #fff176; width: 130px; height: 130px; box-shadow: 0 6px 12px rgba(0,0,0,0.2);">
        </div>

        <div style="display: flex; justify-content: space-around; flex-wrap: wrap; gap: 20px; margin-bottom: 20px;">
            <div style="flex: 1; min-width: 200px; background-color: #c8e6c9; padding: 12px 18px; border-radius: 15px; font-size: 22px; color: #2e7d32; text-align: center;">
                🌟 المستوى: {{ level }}
            </div>
            <div style="flex: 1; min-width: 200px; background-color: #fff9c4; padding: 12px 18px; border-radius: 15px; font-size: 22px; color: #fbc02d; text-align: center;">
                ⭐ النتيجة: <span id="score">{{ score }}</span>
            </div>
            <div style="flex: 1; min-width: 200px; background-color: #e1bee7; padding: 12px 18px; border-radius: 15px; font-size: 22px; color: #6a1b9a; text-align: center;">
                💡 التلميح: <span id="arabic-hint">{{ arabicTranslation|default('لا يوجد تلميح') }}</span>
            </div>
        </div>

        <div id="words" style="display: flex; flex-wrap: wrap; gap: 14px; margin: 25px 0; padding: 20px; background-color: #ffe0b2; border-radius: 25px; justify-content: center;">
            {% if shuffledWords is empty %}
                <p style="color: #d32f2f; font-size: 20px;">🚫 لا توجد عبارة لعرضها.</p>
            {% else %}
                {% for word in shuffledWords %}
                    <span class="word" id="word-{{ loop.index }}" draggable="true" ondragstart="drag(event)" style="padding: 16px 20px; background-color: #4dd0e1; color: white; border-radius: 25px; cursor: grab; font-size: 20px; box-shadow: 3px 3px #0097a7;">
                        {{ word }}
                    </span>
                {% endfor %}
            {% endif %}
        </div>

        <div id="sentence-area" ondrop="drop(event)" ondragover="allowDrop(event)" style="min-height: 70px; padding: 20px; border: 3px dashed #7e57c2; background-color: #f3e5f5; margin-bottom: 30px; border-radius: 25px; display: flex; gap: 14px; flex-wrap: wrap; justify-content: center;"></div>

        <div id="feedback" style="text-align: center; margin: 30px 0; display: none;">
            <img id="feedback-gif" src="" alt="Feedback" style="max-width: 240px; border-radius: 15px;">
            <audio id="feedback-audio" hidden></audio>
            <p id="feedback-message" style="font-size: 26px; font-weight: bold;"></p>
        </div>

        <div id="next-button-container" style="text-align: center; margin: 25px 0; display: none;">
            <button onclick="nextSentence()" style="padding: 16px 32px; background-color: #f06292; color: white; border: none; border-radius: 25px; cursor: pointer; font-size: 22px; box-shadow: 4px 4px #f8bbd0;">
                التالي ⏭️
            </button>
        </div>
    </div>

    <script>
        let originalPhrase = "{{ originalPhrase|default('') }}".trim();
        let attemptCount = 0;
        let timeoutId = null;

        function allowDrop(ev) {
            ev.preventDefault();
        }

        function drag(ev) {
            ev.dataTransfer.setData("text", ev.target.id);
        }

        function drop(ev) {
            ev.preventDefault();
            const id = ev.dataTransfer.getData("text");
            const dragged = document.getElementById(id);
            if (dragged) {
                document.getElementById("sentence-area").appendChild(dragged);
                if (document.getElementById("words").children.length === 0) {
                    checkSentence();
                }
            }
        }

        function checkSentence() {
            const sentenceArea = document.getElementById("sentence-area");
            const sentence = Array.from(sentenceArea.children).map(e => e.textContent.trim()).join(" ");
            const isCorrect = sentence === originalPhrase;
            const feedback = document.getElementById("feedback");
            const gif = document.getElementById("feedback-gif");
            const audio = document.getElementById("feedback-audio");
            const message = document.getElementById("feedback-message");

            attemptCount++;

            if (isCorrect) {
                gif.src = "/images/gifs/bravo.gif";
                audio.src = "/sounds/correct.mp3";
                message.textContent = "أحسنت! الجملة صحيحة 👍";
                message.style.color = "green";
                feedback.style.display = "block";
                audio.play();

                fetch(`/dragdrop/check-sentence/{{ child.childId }}`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                    body: `sentence=${encodeURIComponent(sentence)}&score=${document.getElementById("score").textContent}&attempts=${attemptCount}`
                }).then(() => {
                    timeoutId = setTimeout(() => nextSentence(), 3000);
                });
            } else {
                gif.src = "/images/gifs/error.gif";
                audio.src = "/sounds/incorrect.mp3";
                message.textContent = "❌ الجملة غير صحيحة. حاول مرة أخرى!";
                message.style.color = "red";
                feedback.style.display = "block";
                audio.play();
            }
        }

        function nextSentence() {
            if (timeoutId) clearTimeout(timeoutId);
            fetch(`/dragdrop/next-sentence/{{ child.childId }}`, {
                method: 'POST',
                headers: { 'Content-Type': 'application/x-www-form-urlencoded' }
            })
            .then(response => response.json())
            .then(data => {
                if (data.error) {
                    alert(data.error);
                    return;
                }
                window.location.reload();
            });
        }
    </script>
{% endblock %}