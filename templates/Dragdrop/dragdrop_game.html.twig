{% extends 'base.html.twig' %}

{% block body %}
    <style>
        body {
            background: linear-gradient(to bottom right, #ff7f50, #87ceeb);
            font-family: 'Cairo', sans-serif;
            direction: rtl;
            text-align: center;
            margin: 0;
            min-height: 100vh;
            display: flex;
            justify-content: center;
            align-items: center;
            overflow: hidden;
        }

        #game-container {
            max-width: 900px;
            width: 90%;
            margin: 20px;
            padding: 30px;
            background-color: #ffffff;
            border-radius: 20px;
            box-shadow: 0 10px 20px rgba(0, 0, 0, 0.3);
            position: relative;
            border: 4px solid #ff69b4;
            animation: slideIn 0.5s ease-out;
        }

        @keyframes slideIn {
            from {
                transform: translateY(-50px);
                opacity: 0;
            }
            to {
                transform: translateY(0);
                opacity: 1;
            }
        }

        h1 {
            color: #ff0000;
            font-size: 40px;
            margin-bottom: 30px;
            text-shadow: 2px 2px 4px rgba(0, 0, 0, 0.2);
            animation: bounce 1s infinite;
        }

        @keyframes bounce {
            0%, 20%, 50%, 80%, 100% {
                transform: translateY(0);
            }
            40% {
                transform: translateY(-10px);
            }
            60% {
                transform: translateY(-5px);
            }
        }

        .dropdown {
            position: absolute;
            top: 20px;
            left: 20px;
            z-index: 1001;
        }

        .dropdown-btn {
            background-color: #00b7eb;
            color: white;
            padding: 12px 24px;
            border: none;
            border-radius: 12px;
            font-size: 18px;
            cursor: pointer;
            transition: background-color 0.3s, transform 0.2s;
            box-shadow: 0 4px 8px rgba(0, 0, 0, 0.2);
        }

        .dropdown-btn:hover {
            background-color: #0099cc;
            transform: scale(1.1);
        }

        .dropdown-content {
            display: none;
            position: absolute;
            background-color: #ffffff;
            min-width: 140px;
            box-shadow: 0px 8px 16px 0px rgba(0, 0, 0, 0.3);
            z-index: 1000;
            border-radius: 12px;
            overflow: hidden;
            border: 2px solid #ff69b4;
        }

        .dropdown-content a {
            color: #ff0000;
            padding: 14px 18px;
            text-decoration: none;
            display: block;
            font-size: 16px;
            transition: background-color 0.3s;
            cursor: pointer;
        }

        .dropdown-content a:hover {
            background-color: #ffe4e1;
        }

        .dropdown.active .dropdown-content {
            display: block;
        }

        .status-bar {
            display: flex;
            justify-content: space-around;
            gap: 20px;
            flex-wrap: wrap;
            margin-bottom: 40px;
        }

        .status-box {
            flex: 1;
            padding: 18px;
            border-radius: 20px;
            font-size: 22px;
            font-weight: bold;
            transition: transform 0.3s, box-shadow 0.3s;
            box-shadow: 0 4px 8px rgba(0, 0, 0, 0.1);
            background-color: #fff0f5;
        }

        .status-box:hover {
            transform: scale(1.08);
            box-shadow: 0 6px 12px rgba(0, 0, 0, 0.2);
        }

        .level { color: #ff0000; }
        .score { color: #ffd700; }
        .hint { color: #ff69b4; }

        .no-sentence {
            background-color: #fff0f5;
            color: #ff0000;
            font-weight: bold;
            border-radius: 15px;
            padding: 20px;
            margin: 15px 0;
            border: 2px solid #ff69b4;
        }

        #words {
            display: flex;
            flex-wrap: wrap;
            gap: 15px;
            justify-content: center;
            margin: 30px 0;
        }

        .word {
            padding: 15px 20px;
            background-color: #32cd32;
            color: white;
            border-radius: 12px;
            cursor: grab;
            font-weight: bold;
            font-size: 20px;
            transition: transform 0.3s, background-color 0.3s;
            box-shadow: 0 4px 8px rgba(0, 0, 0, 0.2);
        }

        .word:hover {
            transform: scale(1.15);
            background-color: #228b22;
        }

        #sentence-area {
            min-height: 80px;
            padding: 25px;
            border: 4px dashed #00b7eb;
            border-radius: 20px;
            background: linear-gradient(to bottom right, #e6f3fa, #ffffff);
            display: flex;
            flex-wrap: wrap;
            gap: 12px;
            justify-content: center;
            direction: ltr;
            margin-bottom: 25px;
            box-shadow: inset 0 0 10px rgba(0, 0, 0, 0.1);
        }

        #check-button, #reset-button {
            padding: 15px 30px;
            margin: 12px;
            font-size: 20px;
            border: none;
            border-radius: 15px;
            cursor: pointer;
            color: white;
            transition: background-color 0.3s, transform 0.2s;
            box-shadow: 0 4px 8px rgba(0, 0, 0, 0.2);
        }

        #check-button {
            background-color: #00b7eb;
        }

        #check-button:hover {
            background-color: #0099cc;
            transform: scale(1.1);
        }

        #reset-button {
            background-color: #ff69b4;
        }

        #reset-button:hover {
            background-color: #ff1493;
            transform: scale(1.1);
        }

        #feedback-modal {
            display: none;
            position: fixed;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%) scale(0.8);
            background: #fff0f5;
            border: 4px solid #ff69b4;
            border-radius: 20px;
            padding: 30px;
            z-index: 1000;
            text-align: center;
            animation: popIn 0.4s ease-out forwards;
            box-shadow: 0 8px 16px rgba(0, 0, 0, 0.3);
        }

        @keyframes popIn {
            from {
                transform: translate(-50%, -50%) scale(0.8);
                opacity: 0;
            }
            to {
                transform: translate(-50%, -50%) scale(1);
                opacity: 1;
            }
        }

        #success-modal {
            display: none;
            position: fixed;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
            background: #fffaf0;
            border-radius: 20px;
            padding: 20px;
            width: 80%;
            max-width: 400px;
            box-shadow: 0 10px 20px rgba(0, 0, 0, 0.3);
            z-index: 1001;
            text-align: center;
            background: linear-gradient(135deg, #fffaf0, #ffe4b5);
            border: 4px solid #ff69b4;
            animation: bounceIn 0.5s ease-out;
        }

        @keyframes bounceIn {
            0% { transform: translate(-50%, -50%) scale(0); opacity: 0; }
            60% { transform: translate(-50%, -50%) scale(1.1); }
            100% { transform: translate(-50%, -50%) scale(1); opacity: 1; }
        }

        #success-modal .close-btn {
            position: absolute;
            top: 10px;
            right: 10px;
            font-size: 20px;
            color: #ff4040;
            cursor: pointer;
            background: none;
            border: none;
        }

        #success-modal h2 {
            color: #ff0000;
            font-size: 36px;
            margin-bottom: 10px;
        }

        #success-modal p {
            color: #333;
            font-size: 18px;
            margin-bottom: 20px;
        }

        #success-modal .success-animation {
            width: 100px;
            margin: 10px auto;
        }

        #success-modal .description {
            color: #555;
            font-size: 16px;
            margin-bottom: 20px;
        }

        #success-modal .continue-btn {
            background-color: #ffd700;
            color: #ff4500;
            padding: 12px 24px;
            border: none;
            border-radius: 15px;
            font-size: 18px;
            cursor: pointer;
            transition: background-color 0.3s, transform 0.2s;
            box-shadow: 0 4px 8px rgba(0, 0, 0, 0.2);
        }

        #success-modal .continue-btn:hover {
            background-color: #ffc107;
            transform: scale(1.1);
        }

        #pause-overlay {
            display: none;
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(0, 0, 0, 0.8);
            z-index: 999;
            justify-content: center;
            align-items: center;
        }

        #pause-message {
            background: #fff0f5;
            padding: 40px;
            border-radius: 20px;
            text-align: center;
            box-shadow: 0 0 15px rgba(0, 0, 0, 0.4);
            border: 3px solid #ff69b4;
        }

        #pause-message h2 {
            color: #ff0000;
            margin-bottom: 25px;
            font-size: 28px;
        }

        #resume-button {
            padding: 12px 25px;
            background-color: #00b7eb;
            color: white;
            border: none;
            border-radius: 12px;
            cursor: pointer;
            font-size: 18px;
            transition: background-color 0.3s, transform 0.2s;
        }

        #resume-button:hover {
            background-color: #0099cc;
            transform: scale(1.1);
        }

        @media (max-width: 600px) {
            h1 {
                font-size: 30px;
            }

            .status-box {
                font-size: 18px;
                padding: 12px;
            }

            .word {
                padding: 10px 15px;
                font-size: 16px;
            }

            #sentence-area {
                min-height: 60px;
                padding: 20px;
            }

            #check-button, #reset-button {
                padding: 12px 25px;
                font-size: 16px;
            }

            #feedback-gif {
                width: 120px;
            }

            #feedback-message {
                font-size: 20px;
            }

            #success-modal {
                width: 90%;
                padding: 15px;
            }

            #success-modal h2 {
                font-size: 28px;
            }

            #success-modal .continue-btn {
                padding: 10px 20px;
                font-size: 16px;
            }
        }
    </style>

    <div id="game-container">
        <div class="dropdown">
            <button class="dropdown-btn" onclick="toggleDropdown(event)">☰ القائمة</button>
            <div class="dropdown-content">
                <a href="#" onclick="pauseGame(event)">⏸️ إيقاف مؤقت</a>
                <a href="{{ path('child_dashboard', {'parentId': child.parentId.parentId, 'childId': child.childId}) }}" class="btn btn-primary"><i class="fas fa-home"></i> عودة</a>
            </div>
        </div>

        <h1>🎯 لعبة ترتيب الكلمات السحرية</h1>

        <div class="status-bar">
            <div class="status-box level">🌟 المستوى : <span id="level">{{ level }}</span></div>
            <div class="status-box score">⭐ النتيجة : <span id="score">{{ score }}</span></div>
            <div class="status-box hint" id="arabic-hint">💡 التلميح : 
                {{ arabicTranslation is defined and arabicTranslation ? arabicTranslation : 'لا توجد جمل متاحة لهذه اللغة والمستوى.' }}
            </div>
        </div>

        {% if shuffledWords is empty %}
            <div class="no-sentence">🚫 لا توجد عبارة لعرضها.</div>
        {% endif %}

        <div id="words">
            {% for word in shuffledWords %}
                <span class="word" draggable="true" ondragstart="drag(event)">{{ word }}</span>
            {% endfor %}
        </div>

        <div id="sentence-area" ondrop="drop(event)" ondragover="allowDrop(event)"></div>

        <button id="check-button" onclick="checkSentence()">تحقق</button>
        <button id="reset-button" onclick="resetSentence()">🔁 إعادة الترتيب</button>

        <div id="feedback-modal">
            <img id="feedback-gif" src="" alt="Feedback">
            <audio id="feedback-audio"></audio>
            <p id="feedback-message"></p>
        </div>

        <div id="success-modal">
            <button class="close-btn" onclick="hideSuccessModal()">×</button>
            <h2>نجاح</h2>
            <div id="sentence-success-content">
                <p>! إنها إجابة صحيحة، أحسنت التعبير</p>
                <img src="/gifs/bravo.gif" alt="Success animation" class="success-animation">
                <p class="description">أنت الآن في المستوى التالي، استمر في المجهود!</p>
            </div>
            <div id="level-success-content" style="display: none;">
                <p id="level-completion-message"></p>
                <img src="/gifs/bravo.gif" alt="Level complete animation" class="success-animation">
                <p class="description">مبروك! لقد أكملت جميع الجمل في هذا المستوى!</p>
            </div>
            <button class="continue-btn" onclick="continueToNextLevel()">متابعة</button>
        </div>

        <div id="pause-overlay">
            <div id="pause-message">
                <h2>⏸️ اللعبة موقوفة</h2>
                <button id="resume-button" onclick="resumeGame()">استمرار</button>
            </div>
        </div>
    </div>

    <script>
        let draggedWord = null;
        let isPaused = false;
        let currentLevel = {{ level|default(1) }};

        function allowDrop(ev) {
            if (isPaused) return;
            ev.preventDefault();
        }

        function drag(ev) {
            if (isPaused) return;
            draggedWord = ev.target.textContent.trim();
            ev.dataTransfer.setData("text", draggedWord);
        }

        function drop(ev) {
            if (isPaused) return;
            ev.preventDefault();
            const draggedText = ev.dataTransfer.getData("text");

            if (draggedText) {
                const sourceWords = document.querySelectorAll("#words .word");
                for (let word of sourceWords) {
                    if (word.textContent.trim() === draggedText.trim()) {
                        word.remove();
                        break;
                    }
                }

                const word = document.createElement("span");
                word.textContent = draggedText + " ";
                word.className = "word";
                word.setAttribute("draggable", "false");
                document.getElementById("sentence-area").appendChild(word);
                draggedWord = null;
            }
        }

        function showFeedback(isCorrect) {
            const modal = document.getElementById('feedback-modal');
            const gif = document.getElementById('feedback-gif');
            const audio = document.getElementById('feedback-audio');
            const message = document.getElementById('feedback-message');
            const currentLevel = parseInt(document.getElementById('level').textContent);

            if (isCorrect) {
                gif.src = "/gifs/bravo.gif";
                audio.src = "/sounds/correct1.mp3";
                message.textContent = "إجابة صحيحة! ممتاز!";
                message.style.color = "green";
            } else {
                gif.src = "/gifs/error.gif";
                audio.src = "/sounds/incorrect1.mp3";
                message.textContent = "خطأ! حاول مرة أخرى.";
                message.style.color = "red";
            }

            modal.style.display = 'block';
            audio.play().catch(err => console.error('Erreur lors de la lecture du son:', err));

            setTimeout(() => {
                hideFeedback();
                if (isCorrect) {
                    nextSentence();
                }
            }, 3000);
        }

        function hideFeedback() {
            document.getElementById('feedback-modal').style.display = 'none';
        }

        function checkSentence() {
            if (isPaused) return;
            const sentenceArea = document.getElementById("sentence-area");
            const userSentence = Array.from(sentenceArea.children).map(span => span.textContent.trim()).join(" ");
            fetch(`/dragdrop/check-sentence/{{ child.childId }}`, {
                method: 'POST',
                headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                body: 'sentence=' + encodeURIComponent(userSentence)
            })
            .then(response => response.json())
            .then(data => {
                console.log('Check Sentence Response:', data);
                if (data.error) {
                    alert(data.error + (data.message ? ': ' + data.message : ''));
                    return;
                }
                document.getElementById('score').textContent = data.score;
                document.getElementById('level').textContent = data.level;
                currentLevel = data.level; // Mettre à jour le niveau actuel
                showFeedback(data.isCorrect);
            })
            .catch(error => {
                console.error('Error:', error);
                alert('حدث خطأ، حاول مرة أخرى.');
            });
        }

        function resetSentence() {
            if (isPaused) return;
            const sentenceArea = document.getElementById("sentence-area");
            const wordsDiv = document.getElementById("words");
            const sentenceWords = sentenceArea.querySelectorAll(".word");

            sentenceWords.forEach(word => {
                const newWord = document.createElement("span");
                newWord.textContent = word.textContent.trim();
                newWord.className = "word";
                newWord.setAttribute("draggable", "true");
                newWord.setAttribute("ondragstart", "drag(event)");
                wordsDiv.appendChild(newWord);
            });

            sentenceArea.innerHTML = "";
        }

        function nextSentence() {
            if (isPaused) return;
            fetch(`/dragdrop/next-sentence/{{ child.childId }}`, { method: 'POST' })
            .then(response => response.json())
            .then(data => {
                console.log('Next Sentence Response:', data);
                if (data.error) {
                    if (data.error === 'No more sentences available for this level') {
                        // Show level completion modal
                        showSuccessModal(true, currentLevel);
                        return;
                    }
                    alert(data.error);
                    return;
                }
                if (data.gameCompleted) {
                    alert(`لقد أكملت اللعبة! النتيجة النهائية: ${data.finalScore}`);
                    window.location.href = '{{ path('child_dashboard', {'parentId': child.parentId.parentId, 'childId': child.childId}) }}';
                    return;
                }
                
                // Check if moving from level 1 to level 2
                const previousLevel = parseInt(document.getElementById('level').textContent);
                const newLevel = data.currentLevel;
                
                document.getElementById('words').innerHTML = data.shuffledWords.map(w => `<span class="word" draggable="true" ondragstart="drag(event)">${w}</span>`).join('');
                document.getElementById('sentence-area').innerHTML = '';
                document.getElementById('arabic-hint').textContent = `💡 التلميح : ${data.arabicTranslation || 'لا توجد جمل متاحة.'}`;
                document.getElementById('level').textContent = newLevel;
                document.getElementById('score').textContent = data.score;
                
                // Show regular success modal for individual sentence completion
                if (previousLevel === newLevel) {
                    showSuccessModal(false);
                }
            })
            .catch(error => console.error('Error:', error));
        }

        function pauseGame(event) {
            event.preventDefault();
            if (!isPaused) {
                isPaused = true;
                document.getElementById('pause-overlay').style.display = 'flex';
            }
        }

        function resumeGame() {
            isPaused = false;
            document.getElementById('pause-overlay').style.display = 'none';
        }

        function toggleDropdown(event) {
            event.preventDefault();
            const dropdown = event.target.closest('.dropdown');
            dropdown.classList.toggle('active');
        }

        document.addEventListener('click', function(event) {
            const dropdowns = document.querySelectorAll('.dropdown');
            dropdowns.forEach(dropdown => {
                if (!dropdown.contains(event.target)) {
                    dropdown.classList.remove('active');
                }
            });
        });

        function showSuccessModal(isLevelComplete = false, levelId = null) {
            const modal = document.getElementById('success-modal');
            const sentenceContent = document.getElementById('sentence-success-content');
            const levelContent = document.getElementById('level-success-content');
            const levelMessage = document.getElementById('level-completion-message');

            if (isLevelComplete && levelId !== null) {
                sentenceContent.style.display = 'none';
                levelContent.style.display = 'block';
                levelMessage.textContent = `لقد أكملت المستوى ${levelId} -> المستوى ${levelId + 1}!`;
            } else {
                sentenceContent.style.display = 'block';
                levelContent.style.display = 'none';
            }

            modal.style.display = 'block';
        }

        function hideSuccessModal() {
            const modal = document.getElementById('success-modal');
            modal.style.display = 'none';
        }

        function continueToNextLevel() {
            hideSuccessModal();
        }
    </script>
{% endblock %}