{% extends 'base.html.twig' %}

{% block title %}Ajouter un Administrateur{% endblock %}

{% block stylesheets %}
    <link href="{{ asset('css/user_management.css') }}" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css" rel="stylesheet">
{% endblock %}

{% block body %}
    <div class="d-flex">
        <!-- Sidebar -->
        {% include 'admin/sidebar.html.twig' %}

        <!-- Main Content -->
        <div class="main-content flex-grow-1 p-5">
            <h1 class="dashboard-title mb-4">Ajouter un Nouvel Administrateur</h1>

            <div class="add-admin-container glass-card animate__animated animate__fadeInUp">
                <!-- Display flash messages -->
                {% for message in app.flashes('success') %}
                    <div class="alert alert-success alert-dismissible fade show" role="alert">
                        {{ message }}
                        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                    </div>
                {% endfor %}
                {% for message in app.flashes('error') %}
                    <div class="alert alert-danger alert-dismissible fade show" role="alert">
                        {{ message }}
                        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                    </div>
                {% endfor %}

                <!-- Add Admin Form -->
                {{ form_start(form, {'attr': {'class': 'needs-validation', 'novalidate': 'novalidate'}}) }}
                <div class="form-group">
                    <div class="input-wrapper">
                        <i class="fas fa-envelope input-icon"></i>
                        {{ form_widget(form.email, {'attr': {'class': 'form-control creative-input', 'placeholder': 'Adresse email'}}) }}
                        <label class="floating-label" for="{{ form.email.vars.id }}">Adresse email</label>
                    </div>
                    {{ form_errors(form.email) }}
                </div>
                <div class="form-group">
                    <div class="input-wrapper">
                        <i class="fas fa-lock input-icon"></i>
                        {{ form_widget(form.password, {'attr': {'class': 'form-control creative-input', 'placeholder': 'Mot de passe'}}) }}
                        <label class="floating-label" for="{{ form.password.vars.id }}">Mot de passe</label>
                    </div>
                    {{ form_errors(form.password) }}
                </div>
                <div class="d-flex justify-content-center gap-3 mt-4">
                    <button type="submit" class="creative-button">Créer</button>
                    <a href="{{ path('admin_user_management') }}" class="cancel-button ms-2">Annuler</a>
                </div>
                {{ form_end(form) }}
            </div>
        </div>
    </div>
{% endblock %}

{% block javascripts %}
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
		  try {
            // Sidebar toggle
            const sidebarToggle = document.getElementById('sidebarToggle');
            if (sidebarToggle) {
                sidebarToggle.addEventListener('click', function() {
                    document.getElementById('sidebar').classList.toggle('collapsed');
                    document.getElementById('mainContent').classList.toggle('expanded');
                });
            }
        } catch (error) {
            console.error('JavaScript error:', error);
        }
        document.addEventListener('DOMContentLoaded', function () {
            const form = document.querySelector('.needs-validation');
            if (form) {
                form.addEventListener('submit', function (event) {
                    if (!form.checkValidity()) {
                        event.preventDefault();
                        event.stopPropagation();
                    }
                    form.classList.add('was-validated');
                }, false);
            }

            const inputs = document.querySelectorAll('.creative-input');
            inputs.forEach(input => {
                const label = input.nextElementSibling;
                if (label && label.classList.contains('floating-label')) {
                    input.addEventListener('focus', function () {
                        label.classList.add('focused');
                    });
                    input.addEventListener('blur', function () {
                        if (!this.value) {
                            label.classList.remove('focused');
                        }
                    });
                    if (input.value) {
                        label.classList.add('focused');
                    }
                }
            });

            const successMessages = {{ app.flashes('success')|json_encode|raw }};
            const errorMessages = {{ app.flashes('error')|json_encode|raw }};

            if (successMessages.length > 0) {
                successMessages.forEach(message => {
                    Swal.fire({
                        icon: 'success',
                        title: 'Succès',
                        text: message,
                        timer: 3000,
                        showConfirmButton: false
                    });
                });
            }

            if (errorMessages.length > 0) {
                errorMessages.forEach(message => {
                    Swal.fire({
                        icon: 'error',
                        title: 'Erreur',
                        text: message,
                        timer: 3000,
                        showConfirmButton: false
                    });
                });
            }
        });
    </script>
{% endblock %}