{% extends 'base.html.twig' %}

{% block title %}Ajouter une Nouvelle Question{% endblock %}

{% block stylesheets %}
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;600;700&display=swap" rel="stylesheet">
    <style>
        /* Reset and Global Styles */
        html, body {
            height: 100vh !important;
            margin: 0 !important;
            padding: 0 !important;
            background: #f7f5fa !important;
            font-family: 'Poppins', sans-serif !important;
            overflow-x: hidden !important;
            color: #2d3748 !important;
        }

        /* Dashboard Wrapper */
        .dashboard-wrapper {
            display: flex !important;
            min-height: 100vh !important;
        }

        /* Main Content Styling */
        .main-content {
            margin-left: 250px !important;
            width: calc(100% - 250px) !important;
            padding: 20px !important;
            transition: all 0.3s ease !important;
        }

        .main-content.expanded {
            margin-left: 60px !important;
            width: calc(100% - 60px) !important;
        }

        /* Dashboard Title */
        .dashboard-title {
            font-size: 48px !important;
            font-weight: 700 !important;
            color: #2d3748 !important;
            text-shadow: 0 4px 8px rgba(0, 0, 0, 0.1) !important;
            text-align: center !important;
            margin-bottom: 40px !important;
        }

        /* Glassmorphism Card */
        .glass-card {
            background: rgba(255, 255, 255, 0.9) !important;
            border-radius: 15px !important;
            padding: 20px !important;
            backdrop-filter: blur(5px) !important;
            -webkit-backdrop-filter: blur(5px) !important;
            border: 1px solid rgba(0, 0, 0, 0.05) !important;
            box-shadow: 0 4px 15px rgba(0, 0, 0, 0.1) !important;
            transition: transform 0.3s ease, box-shadow 0.3s ease !important;
        }

        .glass-card:hover {
            transform: translateY(-5px) !important;
            box-shadow: 0 6px 20px rgba(0, 0, 0, 0.15) !important;
        }

        /* Creative Button */
        .creative-button {
            background: linear-gradient(135deg, #3498db, #87ceeb) !important;
            color: #ffffff !important;
            font-size: 16px !important;
            font-weight: 600 !important;
            padding: 10px 20px !important;
            border-radius: 25px !important;
            border: none !important;
            box-shadow: 0 4px 15px rgba(0, 0, 0, 0.2) !important;
            transition: transform 0.3s ease, box-shadow 0.3s ease, background 0.3s ease !important;
            text-decoration: none !important;
            display: inline-block !important;
        }

        .creative-button:hover {
            transform: translateY(-3px) !important;
            box-shadow: 0 6px 20px rgba(0, 0, 0, 0.3) !important;
            background: linear-gradient(135deg, #2980b9, #76c0de) !important;
        }

        .creative-button:active {
            transform: scale(0.95) !important;
        }

        /* Cancel Button */
        .cancel-button {
            background: linear-gradient(135deg, #6c757d, #adb5bd) !important;
            color: #ffffff !important;
            font-size: 16px !important;
            font-weight: 600 !important;
            padding: 10px 20px !important;
            border-radius: 25px !important;
            border: none !important;
            box-shadow: 0 4px 15px rgba(0, 0, 0, 0.2) !important;
            transition: transform 0.3s ease, box-shadow 0.3s ease, background 0.3s ease !important;
            text-decoration: none !important;
            display: inline-block !important;
        }

        .cancel-button:hover {
            transform: translateY(-3px) !important;
            box-shadow: 0 6px 20px rgba(0, 0, 0, 0.3) !important;
            background: linear-gradient(135deg, #5c636a, #9ea7af) !important;
        }

        .cancel-button:active {
            transform: scale(0.95) !important;
        }

        /* Glass Input (for Filters and Form Inputs) */
        .glass-input {
            background: rgba(255, 255, 255, 0.9) !important;
            border: 1px solid rgba(0, 0, 0, 0.1) !important;
            color: #2d3748 !important;
            border-radius: 8px !important;
            padding: 8px !important;
            transition: all 0.3s ease !important;
        }

        .glass-input:focus {
            background: rgba(255, 255, 255, 0.95) !important;
            border-color: rgba(0, 0, 0, 0.2) !important;
            box-shadow: 0 0 10px rgba(52, 152, 219, 0.1) !important;
            outline: none !important;
        }

        .glass-input::placeholder {
            color: rgba(45, 55, 72, 0.5) !important;
        }

        /* Form Labels */
        .form-label {
            color: #2d3748 !important;
            font-weight: 500 !important;
            margin-bottom: 5px !important;
        }

        /* List Group Item (for Add Question Form) */
        .list-group-item {
            background: rgba(255, 255, 255, 0.9) !important;
            border: none !important;
            padding: 10px !important;
            color: #2d3748 !important;
        }

        /* Responsive Design */
        @media (max-width: 768px) {
            .main-content {
                margin-left: 60px !important;
                width: calc(100% - 60px) !important;
            }

            .dashboard-title {
                font-size: 32px !important;
            }
        }
    </style>
{% endblock %}

{% block body %}
    <div class="dashboard-wrapper">
        <!-- Sidebar -->
        {% include 'admin/sidebar.html.twig' %}

        <!-- Main Content -->
        <div class="main-content" id="mainContent">
            <div class="container py-5">
                <h1 class="dashboard-title">Ajouter une Nouvelle Question</h1>

                <div class="dashboard-container glass-card">
                    {{ form_start(form, {'attr': {'class': 'row g-3'}}) }}
                        <!-- Theme Selection -->
                        <div class="col-md-4">
                            <div class="list-group-item glass-card">
                                {{ form_label(form.theme) }}
                                {{ form_widget(form.theme, {'attr': {'class': 'form-select glass-input'}}) }}
                            </div>
                        </div>
                        <!-- Level Selection -->
                        <div class="col-md-4">
                            <div class="list-group-item glass-card">
                                {{ form_label(form.level) }}
                                {{ form_widget(form.level, {'attr': {'class': 'form-select glass-input'}}) }}
                            </div>
                        </div>
                        <!-- Language Selection -->
                        <div class="col-md-4">
                            <div class="list-group-item glass-card">
                                {{ form_label(form.language) }}
                                {{ form_widget(form.language, {'attr': {'class': 'form-select glass-input'}}) }}
                            </div>
                        </div>
                        <!-- Question Text -->
                        <div class="col-md-12">
                            <div class="list-group-item glass-card">
                                {{ form_label(form.questionText) }}
                                {{ form_widget(form.questionText, {'attr': {'class': 'form-control form-text-area glass-input'}}) }}
                            </div>
                        </div>
                        <!-- Correct Answer -->
                        <div class="col-md-4">
                            <div class="list-group-item glass-card">
                                {{ form_label(form.correctAnswer) }}
                                {{ form_widget(form.correctAnswer, {'attr': {'class': 'form-control form-text-field glass-input'}}) }}
                            </div>
                        </div>
                        <!-- Incorrect Answer 1 -->
                        <div class="col-md-4">
                            <div class="list-group-item glass-card">
                                {{ form_label(form.incorrectAnswer1) }}
                                {{ form_widget(form.incorrectAnswer1, {'attr': {'class': 'form-control form-text-field glass-input'}}) }}
                            </div>
                        </div>
                        <!-- Incorrect Answer 2 -->
                        <div class="col-md-4">
                            <div class="list-group-item glass-card">
                                {{ form_label(form.incorrectAnswer2) }}
                                {{ form_widget(form.incorrectAnswer2, {'attr': {'class': 'form-control form-text-field glass-input'}}) }}
                            </div>
                        </div>
                        <div class="col-md-12 text-center mt-4">
                            <button type="submit" class="creative-button">Enregistrer</button>
                            <a href="{{ path('admin_fill_in_the_blank_database') }}" class="cancel-button ms-2">Annuler</a>
                        </div>
                    {{ form_end(form, {'render_rest': false}) }}

                    <!-- Display flash messages -->
                    {% for message in app.flashes('success') %}
                        <div class="alert alert-success mt-3" role="alert">
                            {{ message }}
                        </div>
                    {% endfor %}
                    {% for message in app.flashes('error') %}
                        <div class="alert alert-danger mt-3" role="alert">
                            {{ message }}
                        </div>
                    {% endfor %}
                </div>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        // Sidebar toggle
        document.getElementById('sidebarToggle').addEventListener('click', function() {
            document.getElementById('sidebar').classList.toggle('collapsed');
            document.getElementById('mainContent').classList.toggle('expanded');
        });
    </script>
{% endblock %}