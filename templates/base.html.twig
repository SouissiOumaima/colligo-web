<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <title>{% block title %}لعبة مطابقة الصور{% endblock %}</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        body {
           
            background-size: 100% 100%; /* Keep the background fully visible */
            background-color: #87CEEB; /* Fallback color */
            font-family: Arial, sans-serif;
            min-height: 100vh; /* Full viewport height */
            margin: 0; /* Remove default margins */
        }
        .container {
            text-align: center;
            padding: 20px; /* Original padding */
            background: rgba(255, 255, 255, 0.8); /* Original opacity */
            border-radius: 10px;
            margin-top: 20px; /* Original margin */
        }
        .btn-primary {
            background: linear-gradient(to bottom, #4fc3f7, #0288d1);
            border: none;
        }
        .btn-warning {
            background: linear-gradient(to bottom, #ffb300, #ff8f00);
            border: none;
        }
        .btn-danger {
            background: linear-gradient(to bottom, #ff8a65, #f4511e);
            border: none;
        }
        .btn-info {
            background: linear-gradient(to bottom, #ab47bc, #8e24aa);
            border: none;
        }
        .image-box {
            display: flex;
            justify-content: center;
            gap: 10px;
            margin: 20px 0;
        }
        .image-btn {
            border: none;
            background: none;
            padding: 0;
            cursor: pointer;
        }
        .image-btn img {
            transition: transform 0.2s;
        }
        .image-btn img:hover {
            transform: scale(1.1);
        }
        .navigation-box {
            margin-top: 20px;
        }
        .alert {
            margin-bottom: 20px;
        }
    </style>
    {% block stylesheets %}{% endblock %}
</head>
<body>
    {% block body %}{% endblock %}
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    {% block javascripts %}{% endblock %}
</body>
</html>