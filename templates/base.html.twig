<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <title>{% block title %}Welcome!{% endblock %}</title>
    <link href="https://fonts.googleapis.com/css2?family=Comic+Neue&display=swap" rel="stylesheet">
    {% block stylesheets %}{% endblock %}
</head>
<body>
    {% block body %}{% endblock %}
    {% block javascripts %}
        <script src="https://unpkg.com/@hotwired/turbo@latest/dist/turbo.min.js"></script>
        <script>
            document.addEventListener('turbo:submit-start', (event) => {
                console.log('Turbo: Form submission started', event.detail);
            });
            document.addEventListener('turbo:submit-end', (event) => {
                console.log('Turbo: Form submission ended', event.detail);
            });
            document.addEventListener('turbo:visit', (event) => {
                console.log('Turbo: Visit initiated', event.detail);
            });
        </script>
    {% endblock %}
</body>
</html>